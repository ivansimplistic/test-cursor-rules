      },
      {
        "type": "range",
        "id": "items_per_view_desktop",
        "min": 0,
        "max": 9,
        "step": 0.1,
        "unit": "un",
        "label": "Items per view (Desktop)",
        "default": 4
      },
      {
        "type": "range",
        "id": "items_per_view_tablet",
        "min": 0,
        "max": 6,
        "step": 0.1,
        "unit": "un",
        "label": "Items per view (Tablet)",
        "default": 2.4
      },
      {
        "type": "range",
        "id": "items_per_view_mobile",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "unit": "un",
        "label": "Items per view (Mobile)",
        "default": 1.4
      },
      {
        "type": "header",
        "content": "Section settings"
      },
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "Full width",
        "default": true
      },
      {
        "type": "select",
        "id": "head_position",
        "label": "Header position (Desktop)",
        "options": [
          {"value": "top","label": "Top"},
          {"value": "left","label": "Left"}
        ],
