{%- liquid
  assign collectionSelectorItems = ''
  assign customizerAttributes = ''
-%}
{%- capture itemsHtml -%}
  {%- for block in section.blocks -%}
    {%- liquid
      assign colobj = block.settings.collection
      assign colIndex = forloop.index
      assign title = block.settings.title | default: colobj.title
    -%}

    {%- capture collectionSelectorItems -%}
      {{collectionSelectorItems}}
      {%- if section.settings.filter_layout == 'tabs' -%}
        {%- assign isTabs = true -%}
        <div class="collection-item util-tab-wrap" {{ block.shopify_attributes }}>
          <input type="radio" class="visually-hidden" id="{{block.id}}" name="{{section.id}}-collection-selector" value="{{colobj.handle}}" {% if colIndex == 1 %}checked="checked"{% endif %}>
          <label class="util-tab {{section.settings.filter_tab_style}} text-{{section.settings.text_align}} medium-down--{{section.settings.text_align_mobile}} justify-content-{{section.settings.text_align | replace: 'left', 'start' | replace: 'right', 'end'}} medium-down--justify-content-{{section.settings.text_align_mobile | replace: 'left', 'start' | replace: 'right', 'end'}}" for="{{block.id}}">
            {{title}}
          </label>
        </div>
      {%- else -%}
        {%- capture customizerAttributes -%}
          {{customizerAttributes}}
          <span data-selector-value="{{colobj.handle}}" {{block.shopify_attributes}}></span>
        {%- endcapture -%}
        <option value="{{colobj.handle}}" {{ block.shopify_attributes }}>{{title}}</option>
      {%- endif -%}
    {%- endcapture -%}

    {% comment %}
      
    <lazyload-products style="display: none;" 
      data-collection="{{ colobj.handle }}" 
      data-content-color-scheme="color-{{ section.settings.content_color_scheme }}"
      data-cards-color-scheme="color-{{ section.settings.cards_color_scheme }}"
      data-style="{% if colIndex > 1 %}display: none{% endif %}"
    >
    </lazyload-products>    
    {% endcomment %}

    {%- for product in colobj.products limit:10 -%}
      <div class="keen-slider-slide" data-collection="{{colobj.handle}}" {% if colIndex > 1 %}style="display: none"{% endif %}>
        {%- render 'product_card_atc', productCard: product, section: section -%}
      </div>
    {%- endfor -%}
  {%- endfor -%}
{%- endcapture -%}

{%- capture collectionSelector -%}
  <div class="main-feature {{section.settings.filter_layout}} tabs-outer {% if isTabs %}one-line-desktop one-line-mobile {% if section.settings.filter_tab_style == 'v2' and section.settings.filter_line_tabs_full_width %}full-width{% endif %}{% endif %}">
    <div class="{% if section.settings.filter_layout == 'tabs' %}tabs-inner{% endif %} flex align-items-center">
      {%- if section.settings.side_text != "" -%}
        <div class="side-text p0">{{section.settings.side_text}}</div>
      {%- endif -%}
      <div class="{% if isTabs %}tabs-wrap{% endif %} collection-selector-wrapper flex">
        {%- if section.settings.filter_layout == 'tabs' -%}
          {{collectionSelectorItems}}
        {%- else -%}
          {{customizerAttributes}}
          <div class="field">
            {%- render 'icons', icon: 'chevron-down' -%}
            <select name="{{section.id}}-collection-selector">
              {{collectionSelectorItems}}
            </select>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endcapture -%}

{%- render 'section_multi_item_structure', section: section, cardType: 'product', headContentHtml: collectionSelector, itemsHtml: itemsHtml -%}

<style>
  .product-tabs .section-multi-item .richtext-wrap {flex: 1; max-width: 100%;}
  .product-tabs .section-multi-item .text-align-center .text {margin-left: auto; margin-right: auto;}
  .product-tabs .section-multi-item .text-align-right .text {margin-left: auto;}
  .product-tabs .section-multi-item .tabs-inner {margin: calc(var(--tabs-margin) /  2 * -1) 0;}
  .product-tabs .section-multi-item .collection-item:not(:last-child) .util-tab.v1 {margin-right: var(--tabs-margin);}
  {%- if settings.tab2_margin -%}.product-tabs .section-multi-item .collection-item:not(:last-child) .util-tab.v2 {margin-right: 1em;}{%- endif -%}
  .product-tabs .section-multi-item .main-feature {margin-top: 2.5rem;}
  .product-tabs .section-multi-item .main-feature .side-text {flex-shrink: 0; line-height: 1.2; font-weight: 700; margin-right: 1em;}
  .product-tabs .section-multi-item .dropdown .side-text {color: var(--scheme-highlights);}
  .product-tabs .section-multi-item .dropdown .field {background: transparent; color: var(--scheme-highlights); border-color: var(--scheme-highlights); border-top: 0; border-left: 0; border-right: 0; --scheme-icons-color: var(--scheme-highlights);}
  .product-tabs .section-multi-item .dropdown select {font-size: max(1.5em, 16px) !important; font-weight: 700; padding-top: 0.3em; padding-bottom: 0.3em; padding-left: 0;}
  .product-tabs .section-multi-item .dropdown svg {right: 0;}
</style>

<script type="module">
  var section = document.querySelector('#shopify-section-{{section.id}}');
  var selectors = section.querySelectorAll('[name="{{section.id}}-collection-selector"]');
  selectors.forEach((element)=> {
    element.addEventListener('change', (e)=> {
      {%- if section.settings.layout == 'grid' -%}
        section.querySelectorAll('.grid-item').forEach(slide=> {
          slide.style.display = slide.dataset.collection==element.value ? '' : 'none';
        })
      {%- else -%}
        section.querySelectorAll('.keen-slider-slide').forEach(slide=> {
          slide.style.display = slide.dataset.collection==element.value ? '' : 'none';
        })
        section.querySelector('component-carousel').sliderObj.refresh();
      {%- endif -%}
    });
  });

  {% if request.design_mode %}
  section.addEventListener('shopify:block:select', (e)=>{
    if (e.target.dataset.selectorValue) {
      var elem = section.querySelector('option[value="'+e.target.dataset.selectorValue+'"]');
      elem.selected = true;
      elem.closest('select').dispatchEvent(new CustomEvent('change'));

    } else {
      var elem = e.target.querySelector('input');
      elem.checked = true;
      elem.dispatchEvent(new CustomEvent('change'));

    }
  });
  {% endif %}
</script>

{% schema %}
  {
    "name": "Featured Products (Tabs)",
    "class": "type-featured-products-tabs product-tabs",
    "tag": "section",
    "presets": [
      {
        "name": "Featured Products (Tabs)"
      }
    ],
    "settings": [
      {
        "type": "header",
        "content": "Collections filter"
      },
      {
        "type": "select",
        "id": "filter_layout",
        "label": "Layout",
        "options": [
          {"value": "tabs","label": "Tabs"},
          {"value": "dropdown","label": "Dropdown"}
        ],
        "default": "tabs"
      },
      {
        "visible_if": "{{ section.settings.filter_layout == 'tabs' }}",
        "type": "select",
        "id": "filter_tab_style",
        "label": "Tabs style",
        "options": [
          {"value": "v1","label": "Pills"},
          {"value": "v2","label": "Line"}
        ],
        "default": "v1"
      },
      {
        "visible_if": "{{ section.settings.filter_layout == 'tabs' and section.settings.filter_tab_style == 'v2' }}",
        "type": "checkbox",
        "id": "filter_line_tabs_full_width",
        "label": "Line tabs full width"
      },
      {
        "type": "text",
        "id": "side_text",
        "label": "Text next to the tabs/dropdown",
        "info": "This field could be used for a text like 'I'm looking for...'."
      },
      {
        "type": "header",
        "content": "Head"
      },
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow"
      },
      {
        "visible_if": "{{ section.settings.eyebrow != blank }}",
        "type": "range",
        "id": "eyebrow_size",
        "min": 1,
        "max": 5,
        "step": 1,
        "unit": "p",
        "label": "Eyebrow size",
        "default": 3
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Featured Products",
        "info": "Leave blank to use the Collection's title"
      },
      {
        "visible_if": "{{ section.settings.title != blank }}",
        "type": "checkbox",
        "id": "is_h1",
        "label": "This is the first title of the page (H1)"
      },
      {
        "visible_if": "{{ section.settings.title != blank }}",
        "type": "range",
        "id": "title_size",
        "min": -1,
        "max": 6,
        "step": 1,
        "unit": "h",
        "label": "Title size",
        "default": 1,
        "info": "Equivalent to the heading tags."
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text"
      },
      {
        "visible_if": "{{ section.settings.text != blank }}",
        "type": "range",
        "id": "text_size",
        "min": 1,
        "max": 5,
        "step": 1,
        "unit": "p",
        "label": "Text size",
        "default": 3
      },
      {
        "visible_if": "{{ section.settings.text != blank }}",
        "type": "range",
        "id": "text_width",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "em",
        "label": "Text Width",
        "default": 40
      },
      {
        "type": "text",
        "id": "button",
        "label": "Button label"
      },
      {
        "visible_if": "{{ section.settings.button != blank }}",
        "type": "url",
        "id": "link",
        "label": "Button link"
      },
      {
        "visible_if": "{{ section.settings.button != blank }}",
        "type": "select",
        "id": "button_style",
        "label": "Button style",
        "options": [
            {"value": "link", "label": "Link"},
            {"value": "btn", "label": "Button"},
            {"value": "btn v2", "label": "Button V2"}
        ],
        "default": "btn"
      },
      {
        "visible_if": "{{ section.settings.button != blank }}",
        "type": "select",
        "id": "button_position",
        "label": "Button position",
        "options": [
          {"value": "top","label": "Top"},
          {"value": "bottom","label": "Bottom"},
          {"value": "right","label": "Right"}
        ],
        "default": "top"
      },
      {
        "type": "header",
        "content": "Layout (Grid/Carousel)"
      },
      {
        "type": "select",
        "id": "layout",
        "label": "Layout",
        "options": [
          {"value": "carousel","label": "Carousel"},
          {"value": "grid","label": "Grid"}
        ],
        "default": "carousel"
      },
      {
        "visible_if": "{{ section.settings.layout == 'grid' }}",
        "type": "radio",
        "id": "grid_collapsible",
        "label": "Show 'View All' button in grid mode",
        "options": [
          {"value": "desktop","label": "Desktop only"},
          {"value": "mobile","label": "Mobile only"},
          {"value": "desktop_mobile","label": "Desktop and mobile"},
          {"value": "none", "label": "No"}
        ],
        "default": "none"
      },
      {
        "visible_if": "{{ section.settings.layout == 'carousel' }}",
        "type": "checkbox",
        "id": "show_dots",
        "label": "Show Dots",
        "default": true
      },
      {
        "visible_if": "{{ section.settings.layout == 'carousel' }}",
        "type": "checkbox",
        "id": "show_arrows",
        "label": "Show Arrows",
        "default": true
      },
      {
        "visible_if": "{{ section.settings.layout == 'carousel' and section.settings.show_arrows == true }}",
        "type": "select",
        "id": "arrows_position",
        "label": "Arrows",
        "options": [
          {"value": "sides","label": "Sides"},
          {"value": "top","label": "Top"}
        ],
        "default": "top"
      },
      {
        "type": "select",
        "id": "carousel_width",
        "label": "Width (Desktop)",
        "options": [
          {"value": "full","label": "Full"},
          {"value": "container","label": "Container"},          
          {"value": "left","label": "Left container"}
        ],
        "default": "container"
      },
      {
        "type": "select",
        "id": "carousel_width_mobile",
        "label": "Width (Tablet/Mobile)",
        "options": [
          {"value": "full","label": "Full"},          
          {"value": "left","label": "Left container"}
        ],
        "default": "left"
      },
      {
        "visible_if": "{{ section.settings.layout == 'carousel' }}",
        "type": "range",
        "id": "carousel_autoplay",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "s",
        "label": "Autoplay interval",
        "default": 0,
        "info": "0 = off"
      },
      {
        "visible_if": "{{ section.settings.layout == 'carousel' }}",
        "type": "range",
        "id": "carousel_automove",
        "min": 0,
        "max": 3,
        "step": 0.1,
        "unit": "%",
        "label": "Automove speed",
        "default": 0,
