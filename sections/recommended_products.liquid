{%- if section.settings.custom_products != blank -%}
  {%- capture itemsHtml -%}
    {%- assign count = 0 -%}
    {%- for product in section.settings.custom_products -%}
    <div class="keen-slider-slide">
      {%- render 'product_card_atc', productCard: product -%}
      {%- assign count = count | plus: 1 -%}
    </div>
    {%- endfor -%}
  {%- endcapture -%}

  {%- render 'section_multi_item_structure', section: section, cardType: 'product', itemsHtml: itemsHtml, count: count -%}
{%- else -%}

  <script type="module">routes.product_recommendations_url = '{{ routes.product_recommendations_url }}'</script>
  <script src="{{ 'recommended_products.js' | asset_url }}" defer="defer"></script>

  {%- liquid 
    assign ids = product.id | append: ',' 
    if section.settings.recommendation_intent == 'mixed'
      assign limit = 2
      if product.id
        assign limit = limit | minus: 1
      endif 
      for item in cart.items limit: limit
        unless ids contains item.product.id
          assign ids = ids | append: item.product.id | append: ',' 
        endunless
      endfor 
    endif 
  -%}
  <recommended-products style="display: none;" 
    data-product-ids="{{ ids | remove_last: ',' | strip }}" 
    data-limit="{{section.settings.limit | default: 10}}"
    data-intent="{{ section.settings.recommendation_intent }}"
    data-content-color-scheme="color-{{ section.settings.content_color_scheme }}"
    data-cards-color-scheme="color-{{ section.settings.cards_color_scheme }}"
  >
    <template>
      <div class="products-carousel-root">
        {%- render 'section_multi_item_structure', section: section, cardType: 'product' -%}
      </div>
    </template>

  </recommended-products>
{%- endif -%}



{% schema %}
