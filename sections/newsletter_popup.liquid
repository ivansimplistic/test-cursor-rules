{%- assign popupId = section.id -%}
<style>
  #shopify-section-{{section.id}} {display: none; --global-sections-padding: var(--container-padding);}
  .tingle-modal.{{popupId}} .tingle-modal-box {width: 100%; max-width: {{section.settings.popup_max_width}}rem;}
  .tingle-modal #shopify-section-{{section.id}} {display: block;}
</style>

{%- capture contentHtml -%}
  {%- render 'richtext_content', section: section -%}
{%- endcapture -%}
{%- render 'section_image_text_structure', section: section, textColumnHtml: contentHtml -%}

<script type="module">
  {%- assign defaultCookieName = popupId | split: '__' | last | prepend: 'newsletter_'  -%}
  var cookieName = '{% if section.settings.cookie_name != blank %}newsletter_{{section.settings.cookie_name}}{% else %}{{defaultCookieName}}{% endif %}';
{% unless request.design_mode %}
  function setCookie() {
    {% if section.settings.cookie_on_session %}
    Cookies.set(cookieName, 'true');
    {% else %}
    Cookies.set(cookieName, 'true', { expires: 7 });
    {% endif %}
  }
  var openPopup = function(){
    setTimeout(function(){
      var div = document.querySelector('#shopify-section-{{section.id}}');
      if (!document.querySelector('.tingle-modal.tingle-modal--visible')) {
        //open only if there are no other popup already opened
        $s.openModal(div, '{{popupId}}', {close: function() {
          setCookie();
        }});
        var cf = div.querySelector('contact-form');
        cf.addEventListener('submitSuccess', setCookie);
      }
    }, {{section.settings.popup_delay | times: 1000}});
  } 

  if(!Cookies.get(cookieName)) {
    openPopup();
    {% unless section.settings.cookie_on_session %}
  } else {
    Cookies.set(cookieName, 'true', { expires: 7 });
    {% endunless %}
  }
{% endunless %}

{% if request.design_mode %}
  (function(){
    var section = document.getElementById('shopify-section-{{section.id}}');
    var modal;
    section.addEventListener('shopify:section:select', (e)=>{
      modal = $s.openModal(section, '{{popupId}}');
      Cookies.remove(cookieName);
    });
    section.addEventListener('shopify:section:deselect', (e)=>{
      if (modal) {
        modal.close();
      }
    });
  })();
{% endif %}
</script>

