          {
            "type": "checkbox",
            "id": "show_on_mobile",
            "label": "Show",
            "default": true
          },
          {
            "visible_if": "{{ block.settings.show_on_mobile == true }}",
            "type": "range",
            "id": "image_width_mobile",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width",
            "default": 10
          },
          {
            "visible_if": "{{ block.settings.show_on_mobile == true }}",
            "type": "liquid",
            "id": "image_css_mobile",
            "label": "CSS settings",
            "default": "top: 0; right: 0; transform: translate(0, 0) rotate(0deg);",
