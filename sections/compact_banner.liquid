<style>
  {%- if section.settings.sticky -%}
    #shopify-section-{{ section.id }} {position: sticky; top: var(--header-offset); z-index: 5;}
  {%- endif -%}

  #shopify-section-{{ section.id }} {
    --section-padding-top: calc(var(--global-sections-padding) * {{section.settings.section_padding_top | divided_by: 100.00}});
    --section-padding-bottom: calc(var(--global-sections-padding) * {{section.settings.section_padding_bottom | divided_by: 100.00}});
    --text-padding: calc(var(--global-sections-padding) * {{section.settings.text_padding | divided_by: 100.00 | times: 0.5}});
    --text-border-radius: {{section.settings.text_border_radius}}em;
    --blocks-spacing: {{section.settings.blocks_spacing}}rem;
  }
  @media (max-width: {{settings.breakpoint_tablet}}){
    #shopify-section-{{ section.id }} {
      --section-padding-top: calc(var(--global-sections-padding) * {{section.settings.section_padding_top_mobile | divided_by: 100.00}});
      --section-padding-bottom: calc(var(--global-sections-padding) * {{section.settings.section_padding_bottom_mobile | divided_by: 100.00}});
      --text-padding: calc(var(--global-sections-padding) * {{section.settings.text_padding_mobile | divided_by: 100.00 | times: 0.5}});
      --blocks-spacing: {{section.settings.blocks_spacing_mobile}}rem;
    }
  }
</style>
{{ 'compact_banner.css' | asset_url | stylesheet_tag }}

<div class="compact-banner scheme color-{{section.settings.section_color_scheme}} {% if section.settings.section_padding_top > 0 %}padding-top{% endif %} {% if section.settings.section_padding_bottom > 0 %}padding-bottom{% endif %} {% if section.settings.section_color_scheme == section.settings.content_color_scheme %}same-scheme{% endif %} full-width-{{section.settings.full_width}}">
  <div {% unless section.settings.full_width %}class="container"{% endunless %}>
    <div class="content scheme color-{{section.settings.content_color_scheme}} {% if section.settings.text_border and section.settings.full_width == false %}scheme-border-box{% endif %} {% if section.settings.text_border and section.settings.full_width %}scheme-border-top scheme-border-bottom{% endif %}">
      <div class="container flex flex-wrap">
        <div class="wrap richtext-wrap flex flex-wrap align-items-{{section.settings.content_vertical_alignment}} justify-content-{{section.settings.text_align | replace: 'left', 'start' | replace: 'right', 'end'}} large--text-{{section.settings.text_align}} small--justify-content-{{section.settings.text_align_mobile | replace: 'left', 'start' | replace: 'right', 'end'}} small--text-{{section.settings.text_align_mobile}}">
          {%- render 'richtext_content', section: section -%} 
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Compact Banner",
    "class": "sticky-below-header ease-animation type-compact-banner",
    "tag": "section",
    "presets": [
      {
        "name": "Compact Banner",
        "blocks": [
          {
            "type": "content_title"
          },
          {
            "type": "content_text"
          },
          {
            "type": "content_button"
          }
        ]
      }
    ],
	  "settings": [
      {
        "type": "header",
        "content": "Sticky"
      },
      {
        "type": "checkbox",
        "id": "sticky",
        "label": "Make it sticky"
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color_scheme",
        "id": "section_color_scheme",
        "label": "Section color scheme",
        "default": "scheme-1",
        "info": "Only visible when the section is not full width, or the section top/bottom paddings are enabled."
      },
      {
        "type": "color_scheme",
        "id": "content_color_scheme",
        "label": "Content color scheme",
        "default": "scheme-2"
      },
      {
        "type": "header",
        "content": "Text Settings"
      },
      {
        "type": "select",
        "id": "text_align",
        "label": "Text align (Desktop)",
        "options": [
          {"value": "left", "label": "Left"},
          {"value": "center", "label": "Center"}
        ],
        "default": "left",
        "info": "When text is left-aligned, the last Block will stick to the right side of the section on Desktop."
      },
      {
        "type": "select",
        "id": "text_align_mobile",
        "label": "Text align (Mobile)",
        "options": [
          {"value": "left", "label": "Left"},
          {"value": "center", "label": "Center"},
          {"value": "right", "label": "Right"}
        ],
        "default": "center"
      },
      {
        "type": "header",
        "content": "Section Settings"
      },
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "Full Width",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "text_border",
        "label": "Border"
      },
      {
        "type": "range",
        "id": "text_border_radius",
        "min": 0,
        "max": 10,
        "step": 0.2,
        "unit": "em",
        "label": "Border radius",
        "default": 0
      },
      {
        "type": "select",
        "id": "content_vertical_alignment",
        "label": "Content vertical alignment (Desktop)",
        "options": [
          {"value": "start", "label": "Top"},
          {"value": "center", "label": "Center"},
          {"value": "end", "label": "Bottom"}
        ],
        "default": "center"
      },
      {
        "type": "range",
        "id": "blocks_spacing",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "default": 2,
        "unit": "rem",
        "label": "Blocks spacing (Desktop)"
      },
      {
        "type": "range",
        "id": "blocks_spacing_mobile",
        "min": 0,
        "max": 5,
        "step": 0.1,
        "default": 2,
        "unit": "rem",
        "label": "Blocks spacing (Mobile)"
      },
      {
        "type": "header",
        "content": "Padding Desktop"
      },
      {
        "type": "range",
        "id": "text_padding",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Inner padding (Desktop)",
        "default": 100
      },
      {
        "type": "range",
        "id": "section_padding_top",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Outer padding top (Desktop)",
        "default": 0
      },
      {
        "type": "range",
        "id": "section_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Outer padding bottom (Desktop)",
        "default": 0
      },
      {
        "type": "header",
        "content": "Padding Mobile"
      },
      {
        "type": "range",
        "id": "text_padding_mobile",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Inner padding (Mobile)",
        "default": 100
      },
      {
        "type": "range",
        "id": "section_padding_top_mobile",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Outer padding top (Mobile)",
        "default": 0
      },
      {
        "type": "range",
        "id": "section_padding_bottom_mobile",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Outer padding bottom (Mobile)",
        "default": 0
      }
    ],
    "blocks": [
      {
        "type": "content_title",
        "name": "Title",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Get 30% Off"
          },
          {
            "type": "checkbox",
            "id": "is_h1",
            "label": "This is the first title of the page (H1)"
          },
          {
            "type": "range",
            "id": "title_size",
            "min": -1,
            "max": 6,
            "step": 1,
            "unit": "h",
            "label": "Title size",
            "default": 2,
            "info": "Equivalent to the heading tags: 6 = <h6> (smallest), 1 = <h1> (largest), 0 and -1 are even larger."
          }
        ]
      },
      {
        "type": "content_text",
        "name": "Text",
        "settings": [
          {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>On selected products using the code [[CODE123]] at checkout.</p>"
          },
          {
            "type": "select",
            "id": "text_style",
            "label": "Text style",
            "options": [
              {"value": "normal","label": "Body"},
              {"value": "subheading","label": "Subheading"},
              {"value": "small-label","label": "Small label"}
            ],
            "default": "normal"
          },
          {
            "type": "range",
            "id": "text_size",
            "min": 1,
            "max": 5,
            "step": 1,
            "unit": "p",
            "label": "Text size",
            "default": 3
          }
        ]
      },
      {
        "type": "content_button",
