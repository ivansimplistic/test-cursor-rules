          },
          {
            "type": "text",
            "id": "button_2",
            "label": "Button"
          },
          {
            "visible_if": "{{ block.settings.button_2 != blank }}",
            "type": "url",
            "id": "link_2",
            "label": "Link"
          },
          {
            "visible_if": "{{ block.settings.button_2 != blank }}",
            "type": "select",
            "id": "cta_style2",
            "label": "Style",
            "options": [
                {"value": "link", "label": "Link"},
                {"value": "btn", "label": "Button"},
                {"value": "btn v2", "label": "Button v2"}
            ],
            "default": "btn v2"
          }
        ]
      },
      {
        "type": "content_badge",
        "name": "Badge",
        "settings": [
          {
            "type": "text",
            "id": "badge",
            "label": "Badge",
            "default": "Limited"
          },
          {
            "visible_if": "{{ block.settings.badge != blank }}",
            "type": "select",
            "id": "style",
            "label": "Style",
            "options": [
              {"value": "pill", "label": "Pill"},
              {"value": "round", "label": "Round"}
            ],
            "default": "pill"
          }
        ]
      },
      {
        "type": "content_image",
        "name": "Image",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "url",
            "id": "link",
            "label": "Link"
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "range",
            "id": "width",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width (Desktop)",
            "default": 50
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "range",
            "id": "width_mobile",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width (Mobile)",
            "default": 100
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "range",
            "id": "border_radius",
            "min": 0,
            "max": 10,
            "step": 0.2,
            "unit": "em",
            "label": "Border radius",
            "default": 0
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "checkbox",
            "id": "border",
            "label": "Border"
          },
          {
            "type": "header",
            "content": "Caption"
          },
          {
            "type": "richtext",
            "id": "caption",
            "label": "Caption"
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "select",
            "id": "caption_position",
            "label": "Position",
            "options": [
              {"value": "bottom","label": "Bottom"},
              {"value": "right","label": "Right"}
            ],
            "default": "bottom"
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "select",
            "id": "caption_style",
            "label": "Style",
            "options": [
              {"value": "normal","label": "Body"},
              {"value": "heading-font","label": "Heading"},
              {"value": "subheading","label": "Subheading"},
              {"value": "small-label","label": "Small label"}
            ],
            "default": "normal"
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "range",
            "id": "caption_size",
            "min": 1,
            "max": 5,
            "step": 1,
            "unit": "p",
            "label": "Size",
            "default": 4
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "range",
            "id": "caption_spacing",
            "min": 0,
            "max": 5,
            "step": 0.2,
            "unit": "rem",
            "label": "Spacing (Desktop)",
            "default": 1
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "range",
            "id": "caption_spacing_mobile",
            "min": 0,
            "max": 5,
            "step": 0.2,
            "unit": "rem",
            "label": "Spacing (Mobile)",
            "default": 1
          }
        ]
      },
      {
        "type": "newsletter_form",
        "name": "Newsletter form",
        "limit": 1,
        "settings": [
          {
            "type": "header",
            "content": "Success"
          },
          {
            "type": "richtext",
            "id": "success_message",
            "label": "Success",
            "default": "<p>Thanks for subscribing!</p>"
          },
          {
            "type": "header",
            "content": "Submit CTA"
          },
          {
            "type": "select",
            "id": "submit_style",
            "label": "Style",
            "options": [
              {"value": "btn","label": "Button"},
              {"value": "arrow","label": "Arrow"}
            ],
            "default": "btn"
          },
          {
            "type": "text",
            "id": "submit_label",
            "label": "Label",
            "default": "Subscribe"
          },
          {
            "type": "header",
            "content": "Legal footnote"
          },
          {
            "type": "richtext",
            "id": "legal",
            "label": "Legal footnote"
          }
        ]
      },
      {
        "type": "decorative_image",
        "name": "Decorative/Floating image",
        "settings": [
          {
            "type": "select",
            "id": "relative_to",
            "label": "Position relative to",
            "options": [
              {"value": "text-column","label": "Text column"},
              {"value": "block","label": "Current Block"}
            ],
            "default": "block"
          },
          {
            "type": "header",
            "content": "Content"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "type": "range",
            "id": "border_radius",
            "min": 0,
            "max": 10,
            "step": 0.2,
            "unit": "em",
            "label": "Border radius",
            "default": 0
          },
          {
            "type": "checkbox",
            "id": "shadow",
            "label": "Shadow",
            "default": true
          },
          {
            "type": "header",
            "content": "Desktop Settings"
          },
          {
            "type": "checkbox",
            "id": "show_on_desktop",
            "label": "Show",
            "default": true
          },
          {
            "visible_if": "{{ block.settings.show_on_desktop == true }}",
            "type": "range",
            "id": "image_width_desktop",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width",
            "default": 10
          },
          {
            "visible_if": "{{ block.settings.show_on_desktop == true }}",
