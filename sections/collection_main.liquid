<style>
  .collection-grid {
    --items-per-row: {{section.settings.items_per_row}};
    --grid-align: {{section.settings.grid_align}};
  }
  @media (max-width: {{settings.breakpoint_tablet}}) {
    .collection-grid {
      --items-per-row: {{section.settings.items_per_row_tablet}};
    }
  }
  @media (max-width: {{settings.breakpoint_mobile}}) {
    .collection-grid {
      --items-per-row: {{section.settings.items_per_row_mobile}};
    }
  }
  page-manager {
    --section-padding-top: calc(var(--global-sections-padding) * {{section.settings.section_padding_top | divided_by: 100.00}});
    --section-padding-bottom: calc(var(--global-sections-padding) * {{section.settings.section_padding_bottom | divided_by: 100.00}});
    --collection-utils-compensate: {{section.settings.utils_sticky | replace: true, '4em' | replace: false, '0'}};
  }
  @media (max-width: {{settings.breakpoint_mobile}}){
    page-manager {
      --section-padding-top: calc(var(--global-sections-padding) * {{section.settings.section_padding_top_mobile | divided_by: 100.00}});
      --section-padding-bottom: calc(var(--global-sections-padding) * {{section.settings.section_padding_bottom_mobile | divided_by: 100.00}});
    }
  }
</style>

{{ 'collection_main.css' | asset_url | stylesheet_tag }}

{%- if section.settings.filters and collection.all_products_count > 0 -%}
  <style>
    collection-filters {
      --filters-border-radius: {{section.settings.filters_border_radius}}em;
    }
    {%- if section.settings.pagination_mode == 'infinite_scroll' or section.settings.pagination_mode == 'load_more' -%}
    @media (min-width: {{settings.breakpoint_tablet | plus: 0.001}}em){
      collection-filters:not(.layout-button) .filters-inner {position: sticky; top: calc(var(--header-offset) + var(--collection-utils-compensate) + 1.5em); overflow-y: auto; max-height: calc(100vh - var(--header-offset) - calc(1.5em * 2) - var(--collection-utils-compensate));}
    }
    {%- endif -%}
  </style>
  {{ 'collection_filters.css' | asset_url | stylesheet_tag }}
  {{ 'util_accordion.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'util_accordion.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script src="{{ 'pagination.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'collection_main.js' | asset_url }}" defer="defer"></script>

{%- paginate collection.products by section.settings.page_size -%}
  <page-manager class="scheme color-{{section.settings.content_color_scheme}}" data-page-param="{{ paginate.page_param }}" data-pagination-mode="{{section.settings.pagination_mode}}" data-current-page="{{paginate.current_page}}" data-total-pages="{{paginate.pages}}" data-section-id="{{section.id}}" data-items-container-selector="#shopify-section-{{section.id}} .collection-grid" data-item-selector="#shopify-section-{{section.id}} .product-item, #shopify-section-{{section.id}} .collage-item">
    {%- if section.settings.utils_show == true and collection.all_products_count > 0 -%}
      {%- render 'page_top', section: section, source: 'plp', color_scheme: section.settings.utils_color_scheme, sticky: section.settings.utils_sticky, paginate: paginate, filters_layout: section.settings.filters_layout -%}
    {%- endif -%}
    
    <div class="collection-main">
      <div class="container">
        <div class="flex flex-wrap">
          {%- assign filtersApplied = false -%}
          {%- assign sortApplied = false -%}
          {%- if collection.sort_by != collection.default_sort_by and collection.sort_by != blank -%}
            {%- assign sortApplied = true -%}
          {%- endif -%}

          {%- if section.settings.filters and collection.all_products_count > 0 -%}
            {%- render 'collection_filters', section: section, source: collection, storefrontTags: section.settings.filters_allowed_storefront_tags -%}
            {%- for filter in collection.filters -%}
              {%- if filter.active_values.size > 0 -%}
                {%- assign filtersApplied = true -%}
                {%- break -%}
              {%- endif -%}
              {% if filter.type == "price_range" %}
                {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
                  {%- assign filtersApplied = true -%}
                  {%- break -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor-%}
      
          {%- endif -%}
          
          <div id="collection-wrapper-{{collection.id}}" class="collection-wrapper flex-1" tabindex="-1">
            {%- if collection.products.size > 0 -%}
              {% render 'page_manager_helper', type: 'scrollUp', paginate: paginate, paginationMode: section.settings.pagination_mode %}
              <div data-ga-category="Results Grid" class="grid collection-grid" {% if cart.attributes['_grid_layout'] and section.settings.utils_show == true and settings.dz_enable_cart_attribute_grid_layout %} data-grid-layout="{{cart.attributes['_grid_layout']}}"{% endif %}>
                {%- assign orderIndex = paginate.current_offset -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'featured_item' -%}
                    {%- if block.settings.hide_on_filter and filtersApplied -%}
                      {%- continue -%}
                    {%- endif -%}
                    {%- if block.settings.hide_on_sort and sortApplied -%}
                      {%- continue -%}
                    {%- endif -%}
                    {%- if block.settings.show_on_page_number == 0 or block.settings.show_on_page_number == paginate.current_page -%}
                      {%- capture blockId -%}block-{{block.id}}-{{paginate.current_page}}{%- endcapture -%}
                      {%- render 'collage_item', block: block, blockId: blockId, blockClass: 'grid-item', orderIndex: orderIndex, current_page: paginate.current_page -%}
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- for product in collection.products -%}
                  {%- assign orderIndex = orderIndex | plus: 1 -%}
                  <div class="grid-item product-item" style="order: {{orderIndex}}" data-page="{{paginate.current_page}}">
                    {%- render 'product_card_atc', productCard: product, defaultVariant: product.first_available_variant -%}
                  </div>
                {%- endfor -%}
                <page-results-end></page-results-end>
              </div>

              {% render 'page_manager_helper', type: 'scrollDown', paginate: paginate, paginationMode: section.settings.pagination_mode %}
            {%- else -%}
              {%- render 'collection_empty', collection: collection -%}
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </page-manager>
{%- endpaginate -%}

{%- if settings.product_match_title_height_grid -%}
<script type="module">
  function layout() {
    $s.matchHeight(document.querySelectorAll('#shopify-section-{{section.id}} .common-card .title'));
  }
  document.querySelector('#shopify-section-{{section.id}} page-manager').addEventListener('pageLoaded', layout);
  $s.resizeWidthHandle(layout);
</script>
{%- endif -%}


