{{ 'blog_base.css' | asset_url | stylesheet_tag }}
{%- assign currentBlog = blog -%}
{%- if section.settings.featured_blog != blank -%}
  {%- assign currentBlog = blogs[section.settings.featured_blog] -%}
{%- endif -%}
{%- if currentBlog -%}
<style>
  {%- if section.settings.pagination_mode == 'infinite_scroll' or section.settings.pagination_mode == 'load_more' -%}
  @media (min-width: {{settings.breakpoint_tablet | plus: 0.001}}em){
    .blog-sidebar-inner {position: sticky; top: calc(var(--header-offset) + 1.5em); overflow-y: auto; max-height: calc(100vh - var(--header-offset) - 3em); margin-bottom: var(--global-sections-padding);}
  }
  {%- endif -%}

  #shopify-section-{{section.id}} {
    --items-per-row: {{section.settings.items_per_row}};
    --grid-align: {{section.settings.grid_align}};
  }
  @media (max-width: {{settings.breakpoint_tablet}}) {
    #shopify-section-{{section.id}} {
      --items-per-row: {{section.settings.items_per_row_tablet}};
    }
  }
  @media (max-width: {{settings.breakpoint_mobile}}) {
    #shopify-section-{{section.id}} {
      --items-per-row: {{section.settings.items_per_row_mobile}};
    }
  }
</style>

<script src="{{ 'pagination.js' | asset_url }}" defer="defer"></script>

<div class="blog container scheme color-scheme-1">
  {%- assign filtersApplied = false -%}
  {%- if current_tags.size > 0 -%}
    {%- assign filtersApplied = true -%}
  {%- endif -%}
  {%- paginate currentBlog.articles by section.settings.page_size -%}
    <page-manager style="display: block" data-page-param="{{ paginate.page_param }}" data-pagination-mode="{{section.settings.pagination_mode}}" data-current-page="{{paginate.current_page}}" data-total-pages="{{paginate.pages}}" data-section-id="{{section.id}}" data-items-container-selector="#shopify-section-{{section.id}} .articles-wrapper" data-item-selector="#shopify-section-{{section.id}} .article-item, #shopify-section-{{section.id}} .collage-item">
      {% render 'page_manager_helper', type: 'scrollUp', paginate: paginate, paginationMode: section.settings.pagination_mode %}

      <div class="articles-wrapper grid {% if section.settings.items_per_row == 1 and section.settings.zigzag_desktop %}zigzag-desktop{% endif %} {% if section.settings.items_per_row == 1 and section.settings.zigzag_tablet %}zigzag-tablet{% endif %}" data-layout-desktop="{{section.settings.items_per_row}}" data-layout-tablet="{{section.settings.items_per_row_tablet}}" data-layout-mobile="{{section.settings.items_per_row_mobile}}">

        {%- assign orderIndex = paginate.current_offset -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'featured_item' -%}
            {%- if block.settings.hide_on_filter and filtersApplied -%}
              {%- continue -%}
            {%- endif -%}
            {%- if block.settings.show_on_page_number == 0 or block.settings.show_on_page_number == paginate.current_page -%}
              {%- capture blockId -%}block-{{block.id}}-{{paginate.current_page}}{%- endcapture -%}
              {%- render 'collage_item', block: block, blockId: blockId, blockClass: 'grid-item', orderIndex: orderIndex, current_page: paginate.current_page -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        {%- for article in currentBlog.articles -%}
          {%- assign orderIndex = orderIndex | plus: 1 -%}
          <div class="grid-item article-item" style="order: {{orderIndex}}" data-page="{{paginate.current_page}}">
          {%- render 'article_card', article: article -%}
          </div>
        {%- endfor -%}
        <page-results-end></page-results-end>
      </div>

      {% render 'page_manager_helper', type: 'scrollDown', paginate: paginate, paginationMode: section.settings.pagination_mode %}
    </page-manager>
  {%- endpaginate -%}
</div>
{%- endif -%}

{%- if settings.article_match_title_height_grid -%}
  <script type="module">
    function layout() {
      $s.matchHeight(document.querySelectorAll('#shopify-section-{{section.id}} .common-card .title'));
    }
    document.querySelector('#shopify-section-{{section.id}} page-manager').addEventListener('pageLoaded', layout);
    $s.resizeWidthHandle(layout);
  </script>
{%- endif -%}

{% schema %}
  {
    "name": "Blog Main",
    "class": "blog-main blog-sidebar-sibling type-blog-main",
    "presets": [
      {
        "name": "Blog Main"
      }
    ],
    "settings": [
      {
        "type": "blog",
        "id": "featured_blog",
        "label": "Featured blog",
        "info": "Useful when the section is included in a custom page instead of the blog template."
      },
      {
        "type": "color_scheme",
        "id": "cards_color_scheme",
        "label": "Cards color scheme",
        "default": "scheme-1"
      },
      {
        "type": "select",
        "id": "pagination_mode",
        "label": "Pagination mode",
        "options": [
          {
            "value": "pager",
            "label": "Pager"
          },
          {
            "value": "load_more",
            "label": "Load More"
          },
          {
            "value": "infinite_scroll",
            "label": "Infinite Scroll"
          }
        ],
        "default": "pager"
      },
      {
        "type": "range",
        "id": "page_size",
        "min": 6,
        "max": 50,
        "step": 1,
        "label": "Items per page",
        "default": 12
      },
      {
        "type": "range",
        "id": "items_per_row",
        "min": 1,
        "max": 5,
        "step": 1,
        "label": "Items per row (Desktop)",
        "default": 3
      },
      {
        "type": "range",
        "id": "items_per_row_tablet",
        "min": 1,
        "max": 3,
        "step": 1,
        "label": "Items per row (Tablet)",
        "default": 3
      },
      {
        "type": "range",
        "id": "items_per_row_mobile",
        "min": 1,
        "max": 3,
        "step": 1,
        "label": "Items per row (Mobile)",
        "default": 2
      },
      {
        "type": "select",
        "id": "grid_align",
        "label": "Alignment",
        "options": [
          {
            "value": "flex-start",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "flex-end",
            "label": "Right"
          }
        ],
        "default": "flex-start"
      }
    ],
    "blocks": [
      {
        "type": "featured_item",
        "name": "Featured Item",
        "settings": [
          {
            "type": "header",
            "content": "Media"
          },
          {
            "type": "select",
            "id": "media_type",
            "label": "Media type",
            "options": [
              {"value": "image", "label": "Image"},
              {"value": "video", "label": "Video"}
            ],
            "default": "image"
          },
          {
            "visible_if": "{{ block.settings.media_type == 'image' }}",
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "visible_if": "{{ block.settings.media_type == 'video' }}",
            "type": "video",
            "id": "video_mp4",
            "label": "Video (MP4)"
          },
          {
            "visible_if": "{{ block.settings.media_type == 'video' }}",
            "type": "video_url",
            "id": "video_iframe",
            "label": "Video (Youtube/Vimeo)",
            "accept": ["youtube", "vimeo"]
          },
          {
            "type": "header",
            "content": "Content"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Lorem Ipsum",
            "info": "Leave blank to show the object title."
          },
          {
            "type": "checkbox",
            "id": "show_object_title",
            "label": "Show link-object title"
          },
          {
            "type": "richtext",
            "id": "text",
            "label": "Text"
          },
          {
            "type": "checkbox",
            "id": "show_object_info",
            "label": "Show link-object info",
            "info": "Product: price. Collection: qty of products. Blog: qty of articles. Article: date."
          },
          {
            "type": "header",
            "content": "Button"
          },
          {
            "type": "text",
            "id": "button",
            "label": "Button Text",
            "default": "Shop Now"
          },
          {
            "visible_if": "{{ block.settings.button != blank }}",
            "type": "select",
            "id": "cta_style",
            "label": "Button style",
            "options": [
                {"value": "link", "label": "Link"},
                {"value": "btn", "label": "Button"},
                {"value": "floating_button", "label": "Bubble"}
            ],
            "default": "btn"
          },
          {
            "visible_if": "{{ block.settings.button != blank }}",
            "type": "select",
            "id": "cta_size",
            "label": "CTA size",
            "options": [
              {"value": "normal", "label": "Normal"},
              {"value": "smaller", "label": "Smaller"}
            ],
            "default": "smaller"
          },
          {
            "visible_if": "{{ block.settings.button != blank }}",
            "type": "range",
            "id": "cta_spacing",
            "min": 0,
            "max": 3,
            "step": 0.5,
            "unit": "rem",
            "label": "CTA spacing",
            "default": 0
          },
          {
            "type": "header",
            "content": "Text settings"
          },
          {
            "type": "select",
            "id": "text_position",
            "label": "Text position",
            "options": [
                {"value": "justify-content-start align-items-start", "label": "Top left"},
                {"value": "justify-content-center align-items-start", "label": "Top center"},
                {"value": "justify-content-end align-items-start", "label": "Top right"},
                {"value": "justify-content-start align-items-center", "label": "Center left"},
                {"value": "justify-content-center align-items-center", "label": "Center"},
                {"value": "justify-content-end align-items-center", "label": "Center right"},
                {"value": "justify-content-start align-items-end", "label": "Bottom left"},
                {"value": "justify-content-center align-items-end", "label": "Bottom center"},
                {"value": "justify-content-end align-items-end", "label": "Bottom right"}
            ],
            "default": "justify-content-start align-items-end"
          },
          {
            "type": "select",
            "id": "text_align",
            "label": "Text alignment",
            "options": [
                {"value": "left", "label": "Left"},
                {"value": "center", "label": "Center"},
                {"value": "right", "label": "Right"}
            ],
            "default": "left"
          },
          {
            "type": "range",
            "id": "title_size",
            "min": -1,
            "max": 6,
            "step": 1,
            "unit": "h",
            "label": "Title size",
            "default": 3,
            "info": "Equivalent to the heading tags."
          },
          {
            "type": "range",
            "id": "text_size",
            "min": 1,
            "max": 5,
            "step": 1,
            "unit": "p",
            "label": "Text size",
            "default": 3
          },
          {
            "type": "range",
            "id": "text_padding",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Text padding (Desktop)",
            "default": 25
          },
          {
            "type": "range",
            "id": "text_padding_mobile",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Text padding (Mobile)",
            "default": 25
          },
          {
            "type": "header",
            "content": "Colors"
          },
          {
            "type": "color_scheme",
            "id": "content_color_scheme",
            "label": "Color scheme",
            "default": "scheme-3"
          },
          {
            "type": "color",
            "id": "custom_background",
            "label": "Custom background",
            "default": "#999999",
            "info": "Optional"
          },
          {
            "type": "header",
            "content": "Text protection"
          },
          {
            "type": "paragraph",
            "content": "Helps your text be more readable."
          },
          {
            "type": "select",
            "id": "tint_type",
            "label": "Type",
            "options": [
              {"value": "full", "label": "Full"},
              {"value": "box", "label": "Box"},
              {"value": "shadow", "label": "Shadow"}
            ],
            "default": "box"
          },
          {
            "type": "color",
            "id": "tint_color",
            "label": "Color",
            "default": "#000"
          },
          {
            "type": "range",
            "id": "tint_opacity",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Opacity",
            "default": 20
          },
          {
            "type": "range",
            "id": "tint_blur",
            "min": 0,
            "max": 50,
            "step": 1,
            "unit": "px",
            "label": "Blur effect size",
            "default": 24
          },
          {
            "type": "header",
            "content": "Newsletter form"
          },
          {
            "type": "checkbox",
            "id": "newsletter",
            "label": "Display newsletter form"
          },
          {
            "visible_if": "{{ block.settings.newsletter == true }}",
            "type": "richtext",
            "id": "success_message",
            "label": "Success message",
            "default": "<p>Thanks for subscribing!</p>"
          },
          {
            "visible_if": "{{ block.settings.newsletter == true }}",
            "type": "select",
            "id": "submit_style",
            "label": "Submit style",
            "options": [
              {"value": "btn","label": "Button"},
              {"value": "arrow","label": "Arrow"}
            ],
            "default": "arrow"
          },
          {
            "visible_if": "{{ block.settings.newsletter == true }}",
            "type": "text",
            "id": "submit_label",
            "label": "Submit label",
            "default": "Subscribe"
          },
          {
            "type": "header",
            "content": "Settings"
          },
          {
            "type": "select",
            "id": "width",
            "label": "Width",
            "options": [
              {"value": "single","label": "Small"},
              {"value": "double","label": "Medium"},
              {"value": "full-minus1","label": "Full minus 1"},
              {"value": "full-width","label": "Full width"}
            ],
            "default": "single"
          },
          {
            "type": "range",
            "id": "border_radius",
            "min": 0,
            "max": 10,
            "step": 0.2,
            "unit": "em",
            "label": "Border radius",
            "default": 0
          },
          {
            "type": "range",
            "id": "show_on_page_number",
            "min": 0,
            "max": 100,
            "step": 1,
            "label": "Show on page number",
            "default": 1,
            "info": "Use 0 to display the item on all pages."
          },
          {
            "type": "checkbox",
            "id": "hide_on_filter",
            "label": "Hide when a filter is applied",
            "default": true
          },
          {
            "type": "checkbox",
            "id": "hide_on_sort",
            "label": "Hide when sort is applied",
            "default": true
          },
          {
            "type": "range",
            "id": "flex_order_desktop",
            "min": 1,
            "max": 51,
            "step": 1,
            "label": "Item order (Desktop)",
            "default": 1
          },
          {
            "type": "range",
            "id": "flex_order_tablet",
            "min": 1,
            "max": 51,
            "step": 1,
            "label": "Item order (Tablet)",
            "default": 1
          },
          {
            "type": "range",
            "id": "flex_order_mobile",
            "min": 0,
            "max": 51,
            "step": 1,
            "label": "Item order (Mobile)",
            "default": 1
          }
        ]
      }
    ]
  }
{% endschema %}