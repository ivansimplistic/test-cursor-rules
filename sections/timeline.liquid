        "min": 1,
        "max": 5,
        "step": 1,
        "unit": "p",
        "label": "Eyebrow size",
        "default": 3
      },
      {
        "type": "text",
        "id": "timeline_title",
        "label": "Title"
      },
      {
        "visible_if": "{{ section.settings.timeline_title != blank }}",
        "type": "checkbox",
        "id": "timeline_is_h1",
        "label": "This is the first title of the page (H1)"
      },
      {
        "visible_if": "{{ section.settings.timeline_title != blank }}",
        "type": "range",
        "id": "timeline_title_size",
        "min": -1,
        "max": 6,
        "step": 1,
        "unit": "h",
        "label": "Title size",
        "default": 1,
        "info": "Equivalent to the heading tags."
      },
      {
        "type": "richtext",
        "id": "timeline_text",
        "label": "Text"
      },
      {
        "visible_if": "{{ section.settings.timeline_text != blank }}",
        "type": "range",
        "id": "timeline_text_size",
        "min": 1,
        "max": 5,
        "step": 1,
        "unit": "p",
        "label": "Text size",
        "default": 3
      },
      {
        "type": "header",
        "content": "Image"
      },
      {
        "type": "select",
        "id": "image_position",
        "label": "Position",
        "options": [
            {"value": "normal", "label": "Left"},
            {"value": "row-reverse", "label": "Right"}
        ],
        "default": "normal"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      },
      {
        "type": "range",
        "id": "image_width",
        "min": 20,
        "max": 80,
        "step": 1,
        "unit": "%",
        "label": "Width",
        "default": 50
      },
      {
        "type": "range",
        "id": "image_border_radius",
        "min": 0,
        "max": 10,
        "step": 0.2,
        "unit": "em",
        "label": "Border radius",
        "default": 0
      },
      {
        "type": "select",
        "id": "image_fit",
        "label": "Fit within wrapper",
        "options": [
          {"value": "contain", "label": "Contain"},
          {"value": "cover", "label": "Cover"}
