{%- liquid 
  assign disableLazySizes = false
  if section.index == 1 
    assign disableLazySizes = true
  endif
-%}

{{ 'section_timeline.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section_timeline.js' | asset_url }}" defer="defer"></script>
<style> 
  #shopify-section-{{section.id}} .timeline-section {
    --image-width: {{section.settings.image_width}}%;
    --image-border-radius: {{section.settings.image_border_radius | replace: '10', '1000' | append: 'em'}};
    --items-image-border-radius: {{section.settings.items_image_border_radius | replace: '10', '1000' | append: 'em'}};
    --items-text-width: {{section.settings.items_text_width | append: 'em'}};
    --items-title-weight: {{section.settings.items_title_weight}};
    --items-title-text-transform: {{section.settings.items_title_text_transform}};
    --items-title-letter-spacing: {{section.settings.items_title_letter_spacing | divided_by: 10.00}}em;
    --image-fit: {{section.settings.image_fit}};
    --line-color: {{section.settings.line_color}};
    --line-thickness: {{section.settings.line_thickness}}px;
    --dots-color: {{section.settings.dots_color}};
    --dots-label: {{section.settings.dots_color | replace: 'var(--scheme-text-color)', 'var(--scheme-background-color)' | replace: 'var(--scheme-headings-color)', 'var(--scheme-background-color)' | replace: 'var(--scheme-buttons-background)', 'var(--scheme-buttons-label)'}};
    --dots-width: {{section.settings.dots_width}}em;
  }
  @media (min-width: {{settings.breakpoint_tablet | plus: 0.001}}em){
    #shopify-section-{{section.id}} .timeline-section {--items-image-width: {{section.settings.items_image_width}}%;}
  }
  @media (max-width: {{settings.breakpoint_tablet}}){
    #shopify-section-{{section.id}} .timeline-section {--items-image-width: {{section.settings.items_image_width_mobile}}%;}
  }
</style>

{%- capture contentHtml -%}
  {%- if section.settings.content_full_width -%}<div class="{{section.settings.image_position | replace: 'normal', 'large--container-right' | replace: 'row-reverse', 'large--container-left'}}">{%- endif -%}
    <section-timeline class="timeline-section grid {% if section.settings.alternate %}alternate{% endif %} {% if section.settings.image_full_height %}image-full-height{% endif %} large--{{section.settings.image_position}}">
      {%- if section.settings.image != blank -%}
      <div class="grid-item image-column medium-down--one-whole">
        <img class="{% unless disableLazySizes %}lazyload{% endunless %}" alt="{{section.settings.image.alt}}" data-sizes="auto" src="{% render 'image_placeholder', image: section.settings.image %}" {% if disableLazySizes %}fetchpriority="high" {% else %}data-{% endif %}srcset="{% render 'lazy_src', image: section.settings.image %}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" {% if section.settings.image.presentation.focal_point != blank %}style="object-position: {{section.settings.image.presentation.focal_point}};"{% endif %}>
      </div>
      {%- endif -%}
      <div class="grid-item large--flex-1 medium-down--one-whole steps-column">
        {%- if section.settings.content_full_width -%}<div class="medium-down--container">{%- endif -%}
          {%- if section.settings.timeline_text != blank and section.settings.timeline_text != '<p></p>' -%}
            {% assign hasHeadingText = true %}
          {%- endif -%}
          {%- if section.settings.timeline_eyebrow != blank or section.settings.timeline_title != blank or hasHeadingText -%}
            <div class="heading richtext-wrap {% if section.settings.alternate %}large--text-center{% endif %}">
              {%- if section.settings.timeline_eyebrow != blank -%}
                <div class="subheading {{section.settings.timeline_eyebrow_size | prepend: 'p'}}">{{ section.settings.timeline_eyebrow }}</div>
              {%- endif -%}
              {%- if section.settings.timeline_title != blank -%}
                {{ '<' }}{%- if section.settings.timeline_is_h1 -%}h1{%- else -%}h2{%- endif %} class="title {{section.settings.timeline_title_size | replace: 0, '1-xl' | replace: -1, '1-xxl' | prepend: 'h' }}"{{ '>' }} {{ section.settings.timeline_title }} {{ '</' }}{%- if section.settings.timeline_is_h1 -%}h1{%- else -%}h2{%- endif %}{{ '>' }}
              {%- endif -%}
              {%- if section.settings.timeline_text != blank and section.settings.timeline_text != '<p></p>' -%}
                <div class="text {{section.settings.timeline_text_size | prepend: 'p'}}">{{ section.settings.timeline_text }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
          <div class="steps">
            <div class="line"></div>
            {%- for block in section.blocks -%}
            <div class="item flex {% if section.settings.alternate %}large--justify-content-center{% endif %} {% if forloop.first %}first{% elsif forloop.last %}last{% endif %}" {{ block.shopify_attributes }}>
              {%- if section.settings.alternate -%}
                <div class="info opposite text-left ease-animation-slow medium-down--hide">
                  {%- if block.settings.image != blank and section.settings.items_image_position_opposite -%}
                    <div class="img-wrap">
                      <img class="{% unless disableLazySizes %}lazyload{% endunless %}" alt="{{block.settings.image.alt}}" data-sizes="auto" src="{% render 'image_placeholder', image: block.settings.image %}" {% if disableLazySizes %}fetchpriority="high" {% else %}data-{% endif %}srcset="{% render 'lazy_src', image: block.settings.image %}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" {% if block.settings.image.presentation.focal_point != blank %}style="object-position: {{block.settings.image.presentation.focal_point}};"{% endif %}>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
              <div class="number-wrap">
                <div class="number ease-animation-slow {{section.settings.color_scheme}} scheme-invert">
                  <span class="ease-animation-slow">
                    {% if section.settings.show_numbers %}<strong>{{forloop.index}}</strong>{% endif %}
                  </span>
                </div>
              </div>
              <div class="info text-left ease-animation-slow flex {{section.settings.items_image_position}}">
                {%- if block.settings.text != blank and block.settings.text != '<p></p>' -%}
                  {%- assign hasTextField = true -%}
                {%- endif -%}
                {%- if block.settings.eyebrow != "" or block.settings.title != "" or hasTextField -%}
                  <div class="wrap">
                    {%- if block.settings.eyebrow != "" -%}
                      <div class="eyebrow small-label {{section.settings.items_eyebrow_size | prepend: 'p'}}">{{block.settings.eyebrow}}</div>
                    {%- endif -%}
                    {%- if block.settings.title != "" -%}
                      {%- assign title2Tag = section.settings.timeline_is_h1 | replace: true, 'h2' | replace: false, 'h3' -%}
                      <{{title2Tag}} class="title {{section.settings.items_title_font_family}} {{section.settings.items_title_size | replace: 0, '1-xl' | replace: -1, '1-xxl' | prepend: 'h' }}">{{block.settings.title}}</{{title2Tag}}>
                    {%- endif -%}
                    {%- if hasTextField -%}
                      <div class="description {{section.settings.items_text_size | prepend: 'p'}}">{{block.settings.text}}</div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  <div class="img-wrap {% if section.settings.items_image_position_opposite %}hide medium-down--show{% endif %}">
                    <img class="{% unless disableLazySizes %}lazyload{% endunless %}" alt="{{block.settings.image.alt}}" data-sizes="auto" src="{% render 'image_placeholder', image: block.settings.image %}" {% if disableLazySizes %}fetchpriority="high" {% else %}data-{% endif %}srcset="{% render 'lazy_src', image: block.settings.image %}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" {% if block.settings.image.presentation.focal_point != blank %}style="object-position: {{block.settings.image.presentation.focal_point}};"{% endif %}>
                  </div>
                {%- endif -%}
              </div>
            </div>
            {%- endfor -%}
          </div>
        {%- if section.settings.content_full_width -%}</div>{%- endif -%}
      </div>
    </section-timeline>
  {%- if section.settings.content_full_width -%}</div>{%- endif -%}
{%- endcapture -%}

{%- render 'section_custom_structure', section: section, contentHtml: contentHtml -%}

