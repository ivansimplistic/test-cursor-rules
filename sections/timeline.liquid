          },
          {
            "value": "var(--scheme-headings-color)",
            "label": "Headings color"
          },
          {
            "value": "var(--scheme-buttons-background)",
            "label": "Buttons color"
          }
        ],
        "default": "var(--scheme-text-color)"
      },
      {
        "type": "select",
        "id": "dots_color",
        "label": "Dots color",
        "options": [
          {
            "value": "var(--scheme-text-color)",
            "label": "Text color"
          },
          {
            "value": "var(--scheme-headings-color)",
            "label": "Headings color"
          },
          {
            "value": "var(--scheme-buttons-background)",
            "label": "Buttons color"
          }
        ],
        "default": "var(--scheme-text-color)"
      },
      {
        "type": "range",
