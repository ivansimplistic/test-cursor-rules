<style>
  #shopify-section-{{section.id}} > * {display: none;}
</style>
{%- assign allCol = collections['all'] | default: collections['all-products'] -%}
{%- if collection.handle == allCol.handle and allCol.handle != blank -%}
   <!-- begin of ajax pulled content -->
  <div class="swatches-modal-html swatches-modal-wrapper scheme color-scheme-1">
    {{ 'product_card_atc.css' | asset_url | stylesheet_tag }}
    <style>
      .swatches-modal-html {width: 32em; max-width: 100%;}
      .swatches-modal-wrapper {padding: 2em 1em;}
      .swatches-modal-wrapper .swatches-modal-content {max-height: 80vh; display: flex; flex-flow: column;}
      .swatches-modal-wrapper .swatches-list {overflow: auto;}
      .swatches-modal-wrapper .swatches-list-content {flex-shrink: 1; flex-grow: 1; width: max-content; max-width: 100%; padding: 0.75em;}
      .swatches-modal-wrapper .result {flex-shrink: 0; flex-grow: 0; padding-top: 1em;}
      .swatches-modal-wrapper .result #swatches-css {height: 8em; font-family: monospace; line-height: 1.3; white-space: nowrap;}
      .swatches-modal-wrapper .color-swatches {display: flex; gap: 2em; margin-bottom: 0.5em;}
      .swatches-modal-wrapper .color-name {flex-grow: 1; line-height: 1.2; display: flex; align-items: center;}
      .swatches-modal-wrapper .color-swatches .color {flex-shrink: 0;}
      .swatches-modal-wrapper .color-swatches .status {width: 7em; flex-shrink: 0; line-height: 1.2; display: flex; align-items: center;}
      .swatches-modal-wrapper .color-empty {background: linear-gradient(-45deg, white, white 45%, red, white 55%, white);}
      .swatches-modal-wrapper .color-empty ~ .status {color: var(--scheme-errors-color);}
      .swatches-modal-wrapper .note {font-size: 0.9em; color: var(--scheme-errors-color);}
      .swatches-modal-wrapper .small {font-size: 0.8125em;}
      .swatches-modal-wrapper .color-swatches .label-inner {display: block; position: relative; border: 1px solid var(--scheme-borders-color); border-radius: 5em; padding: 0.75em; -webkit-transition: all .2s linear; -moz-transition: all .2s linear; -o-transition: all .2s linear; -ms-transition: all .2s linear; transition: all .2s linear;}
    </style>
    <div class="swatches-modal-content">
      <h2>Color Swatches Helper</h2>
      <div class="swatches-list product-card atc scheme-border-box">
        <div class="swatches-list-content">
        {%- assign colorSwatchesOptions = settings.product_color_swatches | replace: ', ', ',' | split: ',' -%}
        {%- for filter in allCol.filters -%}
          {%- if filter.type == 'list' and colorSwatchesOptions contains filter.label -%}
            {%- for value in filter.values -%}
              <div class="color-swatches" data-value="{{value.value | replace: '&quot;', '"' | handle}}">
                <span class="color-name">{{value.value}}</span>
                <div class="color label-inner color-empty color-{{ value.value | replace: '&quot;', '"' | handle }}">
                </div> 
                <span class="status">not specified</span>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
        </div>
      </div>
      <div class="small">*Only existing product options are shown</div>
      <div class="result">
        <label for="swatches-css">CSS Export</label>
        <div class="note">Update pending:<br> copy and paste this content into Theme Settings -&gt; Products -&gt; Variant Selection: CSS</div>
        <div class="field textarea no-label">
          <textarea id="swatches-css"></textarea>
        </div>
        <textarea style="display:none" id="theme-swatches-css">{{settings.color_swatches_css}}</textarea>
      </div>
    </div>
    <script type="module">
      var blocks = [
      {% for block in section.blocks %}
        {% if forloop.index > 1%},{% endif %}
        {
          "color_name": {{block.settings.title | handleize | json}},
          "color_flat": {% if block.settings.color_flat != 'rgba(0,0,0,0)' %}{{block.settings.color_flat | json}}{% else %}''{% endif %},
          "color_background": {{block.settings.color_background | json}},
          "image": {% if block.settings.image != blank %}{{block.settings.image | image_url: width: 80 | json}}{% else %}null{% endif %},
        }
      {% endfor %}
      ]
      var section = document.querySelector('.swatches-modal-wrapper');
      var txt1 = document.getElementById('swatches-css');
      var txt2 = document.getElementById('theme-swatches-css');
      blocks.forEach(block=>{
        if (block.color_name) {
          var item = section.querySelector('.color-swatches[data-value="'+block.color_name+'"]');
          var text = '';
          var css = '';
          var empty = false;
          if (block.image) {
            text = 'Image';
            css = 'background-image: url(\''+block.image+'\')';
          } else if (block.color_background) {
            text = 'CSS Gradient';
            css = 'background: ' + block.color_background;
          } else if (block.color_flat) {
            text = 'Flat color';
            css = 'background: ' + block.color_flat;
          } else {
            empty = true;
          }
          if (item && !empty) {
            var swatch = item.querySelector('.color');
            var status = item.querySelector('.status');
            status.innerHTML = text;
            swatch.setAttribute('style', css);
            swatch.classList.remove('color-empty');
          }
          if (!empty) {
            txt1.value += '.color-'+block.color_name+' {'+css+';}\n';
          }
        
        }
      });
      section.querySelector('.note').style.display = txt1.value.trim()==txt2.value.trim().replaceAll('\r\n','\n') ? 'none' : '';
    </script>
  </div>
  <!-- end of ajax pulled content -->
{%- endif -%}
<script type="module">
  var mustLoadData = false;
  {%- unless collection.handle == allCol.handle and allCol.handle != blank -%}  
    mustLoadData = true;
    async function loadData(){
      mustLoadData = false;
      var section = document.querySelector('#shopify-section-{{section.id}}');
      var colHandle = '{{allCol.handle}}';
      if (colHandle) {
        var data = await $s.get({url: '{{ routes.collections_url }}' +'/'+colHandle+'?section_id=color_swatches'});
        var doc = new DOMParser().parseFromString(data, 'text/html');
        var html = doc.querySelector('.swatches-modal-html');
        section.insertAdjacentElement('afterbegin', html);
        $s.globalEval(html.innerHTML);
      }
    }
  {%- endunless -%}
  (function(){
    var section = document.getElementById('shopify-section-{{section.id}}');
    var modal;
    section.addEventListener('shopify:section:select', async (e)=>{
      if (mustLoadData) {
        await loadData();
      }
      var content = section.querySelector('.swatches-modal-html');
      modal = $s.openModal(content, 'swatches-modal', {closeMethods: []});
    });
    section.addEventListener('shopify:section:deselect', (e)=>{
      if (modal) {
        modal.close();
      }
    });
  })();

</script>

{% schema %}
{
  "name": "Color Swatches Helper",
  "class": "type-color-swatches-helper",
  "settings": [
  ],
  "blocks": [
    {
      "type": "swatch",
      "name": "Swatch",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Color name"
        },
        {
          "type": "color",
          "id": "color_flat",
          "label": "Flat color"
        },
        {
          "type": "color_background",
          "id": "color_background",
          "label": "CSS Gradient"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "paragraph",
          "content": "Save changes and wait a few seconds to see the preview modal updated"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "swatch"
      }
    ]
  }
}
{% endschema %}