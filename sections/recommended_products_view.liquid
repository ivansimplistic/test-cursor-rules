<div class="recommended-view">
  {%- if recommendations.products_count > 0 -%}
    {%- for product in recommendations.products -%}
      {%- unless product.metafields.seo.hidden == 1 -%}
        <div class="keen-slider-slide" data-recommendation-type="{{ recommendations.intent | default: 'related' }}">
          {%- render 'product_card_atc', productCard: product -%}
        </div>
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}
</div>