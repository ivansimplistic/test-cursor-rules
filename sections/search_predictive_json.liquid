{%- capture results -%}
  {%- for product in predictive_search.resources.products limit:6 -%}
    {%- assign image = product.selected_or_first_available_variant.image | default: product.featured_image -%}
    { 
      "title"    : {{ product.title | json }},
      "url"      : {{ product.url | json }},
      "thumbnail": {% if image != blank %}{{ image | image_url: width: 180 | json }}{% else %}{{ 'placeholder_image.svg' | asset_url | json}}{% endif %},
      "price": {{ product.selected_or_first_available_variant.price | default: product.price_min }}
    }
    {%- unless forloop.last %},{%- endunless -%}
  {%- endfor -%}
{%- endcapture -%}
{%- capture resultsArticles -%}
  {%- for item in predictive_search.resources.articles limit:6 -%}
    {%- assign image = item.image -%}
    { 
      "title"    : {{ item.title | json }},
      "url"      : {{ item.url | json }},
      "thumbnail": {% if image != blank %}{{ image | image_url: width: 180 | json }}{% else %}{{ 'placeholder_image.svg' | asset_url | json}}{% endif %}
    }
    {%- unless forloop.last %},{%- endunless -%}
  {%- endfor -%}
{%- endcapture -%}
{%- capture resultsPages -%}
  {%- for item in predictive_search.resources.pages limit:6 -%}
      { 
        "title"    : {{ item.title | json }},
        "url"      : {{ item.url | json }}
      }
    {%- unless forloop.last %},{%- endunless -%}
  {%- endfor -%}
{%- endcapture -%}
{%- capture suggestedCollections -%}
  {%- for collection in predictive_search.resources.collections limit:6 -%}
    {%- assign image = collection.image | default: collection.products[0].images[0] -%}
    { 
      "title"    : {{ collection.title | json }},
      "url"      : {{ collection.url  | json }},
      "thumbnail": {% if image != blank %}{{ image | image_url: width: 180 | json }}{% else %}{{ 'placeholder_image.svg' | asset_url | json}}{% endif %},
      "products_count": {{ collection.products_count }}
    }
    {%- unless forloop.last %},{%- endunless -%}
  {%- endfor -%}
{%- endcapture -%}
{
  "results_count": 99,
  "results": [{{ results }}],
  "articles": [{{ resultsArticles }}],
  "pages": [{{ resultsPages }}],  
  "collections": [{{ suggestedCollections }}]
}