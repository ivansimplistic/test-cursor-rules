{{ 'customer_forms.css' | asset_url | stylesheet_tag }}
{%- render 'customer_forms_js_inc' -%}
<div class="customer-form-page text-center scheme color-{{settings.customer_portal_color_scheme}}">
  <div class="container">

    {%- render 'form_login' -%}
    
    <div id="customer-new-account">
      <h2>{{ 'account.login.new_customer_title' | t }}</h2>
      <a class="btn" href="{{ routes.account_register_url }}">{{ 'account.login.new_customer_link' | t }}</a>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Login",
    "class": "type-login"
  }
{% endschema %}