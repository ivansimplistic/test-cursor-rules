{%- capture contentHtml -%}
  {%- render 'richtext_content', section: section -%}
{%- endcapture -%}
{%- render 'section_banner_structure', mode: 'banner', section: section, textColumnHtml: contentHtml -%}

{% schema %}
  {
    "name": "Password",
    "class": "shopify-section-password type-password",
    "tag": "section",
    "settings": [
      {
        "type": "header",
        "content": "Desktop Media"
      },
      {
        "type": "select",
        "id": "media_type",
        "label": "Media type",
        "options": [
          {"value": "image", "label": "Image"},
          {"value": "video", "label": "Video"}
        ],
        "default": "image"
      },
      {
        "visible_if": "{{ section.settings.media_type == 'video' }}",
        "type": "video",
        "id": "video_mp4_desktop",
        "label": "Video (MP4)"
      },
      {
        "visible_if": "{{ section.settings.media_type == 'video' }}",
        "type": "video_url",
        "id": "video_iframe_desktop",
        "label": "Video (Youtube/Vimeo)",
        "accept": ["youtube", "vimeo"]
      },
      {
        "visible_if": "{{ section.settings.media_type == 'image' }}",
        "type": "image_picker",
        "id": "image_desktop",
        "label": "Image"
      },
      {
        "type": "header",
        "content": "Mobile Media"
      },
      {
        "type": "paragraph",
        "content": "If left blank, Mobile inherits what was set up for Desktop."
      },
      {
        "type": "select",
        "id": "media_type_mobile",
        "label": "Media type",
        "options": [
          {"value": "image", "label": "Image"},
          {"value": "video", "label": "Video"}
        ],
        "default": "image"
      },
      {
        "visible_if": "{{ section.settings.media_type_mobile == 'video' }}",
        "type": "video",
        "id": "video_mp4_mobile",
        "label": "Video (MP4)"
      },
      {
        "visible_if": "{{ section.settings.media_type_mobile == 'video' }}",
        "type": "video_url",
        "id": "video_iframe_mobile",
        "label": "Video (Youtube/Vimeo)",
        "accept": ["youtube", "vimeo"]
      },
      {
        "visible_if": "{{ section.settings.media_type_mobile == 'image' }}",
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Image"
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color_scheme",
        "id": "content_color_scheme_desktop",
        "label": "Color scheme (Desktop)",
        "default": "scheme-3"
      },
      {
        "type": "color_scheme",
        "id": "content_color_scheme_mobile",
        "label": "Color scheme (Mobile)",
        "default": "scheme-2"
      },
      {
        "type": "color",
        "id": "custom_background_desktop",
        "label": "Custom background (Desktop)",
        "default": "#999999",
        "info": "Optional"
      },
      {
        "type": "color",
        "id": "custom_background_mobile",
        "label": "Custom background (Mobile)",
        "info": "Optional"
      },
      {
        "type": "color_scheme",
        "id": "section_color_scheme",
        "label": "Outer section color scheme",
        "default": "scheme-1",
        "info": "Visible only when the section padding is enabled or full width is disabled."
      },
      {
        "type": "header",
        "content": "Text protection"
      },
      {
        "type": "checkbox",
        "id": "tint_enable",
        "label": "Show text protection",
        "default": true,
        "info": "Helps your text be more readable."
      },
      {
        "visible_if": "{{ section.settings.tint_enable == true }}",
        "type": "select",
        "id": "tint_type",
        "label": "Type",
        "options": [
          {"value": "full", "label": "Full"},
          {"value": "box", "label": "Box"},
          {"value": "shadow", "label": "Shadow"}
        ],
        "default": "box"
      },
      {
        "visible_if": "{{ section.settings.tint_enable == true }}",
        "type": "color",
        "id": "tint_color",
        "label": "Color",
        "default": "#000"
      },
      {
        "visible_if": "{{ section.settings.tint_enable == true }}",
        "type": "range",
        "id": "tint_opacity",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%",
        "label": "Opacity",
        "default": 20
      },
      {
        "visible_if": "{{ section.settings.tint_enable == true and section.settings.tint_type != 'shadow' }}",
        "type": "range",
        "id": "tint_border_radius",
        "min": 0,
        "max": 10,
        "step": 0.2,
        "unit": "em",
        "label": "Text box border radius",
        "default": 0
      },
      {
        "visible_if": "{{ section.settings.tint_enable == true }}",
        "type": "range",
        "id": "tint_blur",
        "min": 0,
        "max": 50,
        "step": 1,
        "unit": "px",
        "label": "Blur effect size",
        "default": 24
      },
      {
        "type": "header",
        "content": "Text settings"
      },
      {
        "type": "range",
        "id": "text_width",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "em",
        "label": "Width (Desktop)",
        "default": 40
      },
      {
        "type": "range",
        "id": "text_padding",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Padding (Desktop)",
        "default": 80
      },
      {
        "type": "select",
        "id": "text_position_desktop",
        "label": "Position (Desktop)",
        "options": [
            {"value": "justify-content-start align-items-start", "label": "Top left"},
            {"value": "justify-content-center align-items-start", "label": "Top center"},
            {"value": "justify-content-end align-items-start", "label": "Top right"},
            {"value": "justify-content-start align-items-center", "label": "Center left"},
            {"value": "justify-content-center align-items-center", "label": "Center"},
            {"value": "justify-content-end align-items-center", "label": "Center right"},
            {"value": "justify-content-start align-items-end", "label": "Bottom left"},
            {"value": "justify-content-center align-items-end", "label": "Bottom center"},
            {"value": "justify-content-end align-items-end", "label": "Bottom right"}
        ],
        "default": "justify-content-center align-items-center"
      },
      {
        "type": "select",
        "id": "text_align_desktop",
        "label": "Alignment (Desktop)",
        "options": [
            {"value": "text-left", "label": "Left"},
            {"value": "text-center", "label": "Center"},
            {"value": "text-right", "label": "Right"}
        ],
        "default": "text-center"
      },
      {
        "type": "range",
        "id": "text_width_mobile",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "em",
        "label": "Width (Mobile)",
        "default": 30
      },
      {
        "type": "range",
        "id": "text_padding_mobile",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Padding (Mobile)",
        "default": 100
      },
      {
        "type": "select",
        "id": "text_position_mobile",
        "label": "Position (Mobile)",
        "options": [
            {"value": "justify-content-start align-items-start", "label": "Top left"},
            {"value": "justify-content-center align-items-start", "label": "Top center"},
            {"value": "justify-content-end align-items-start", "label": "Top right"},
            {"value": "justify-content-start align-items-center", "label": "Center left"},
            {"value": "justify-content-center align-items-center", "label": "Center"},
            {"value": "justify-content-end align-items-center", "label": "Center right"},
            {"value": "justify-content-start align-items-end", "label": "Bottom left"},
            {"value": "justify-content-center align-items-end", "label": "Bottom center"},
            {"value": "justify-content-end align-items-end", "label": "Bottom right"}
        ],
        "default": "justify-content-center align-items-center"
      },
      {
        "type": "select",
        "id": "text_align_mobile",
        "label": "Alignment (Mobile)",
        "options": [
            {"value": "text-left", "label": "Left"},
            {"value": "text-center", "label": "Center"},
            {"value": "text-right", "label": "Right"}
        ],
        "default": "text-center"
      },
      {
        "type": "header",
        "content": "Desktop Settings"
      },
      {
        "type": "select",
        "id": "section_height",
        "label": "Section Height",
        "options": [
          {"value": "small","label": "Small"},
          {"value": "medium","label": "Medium"},
          {"value": "large","label": "Large"},
          {"value": "first_image","label": "Image height"},
          {"value": "window_height","label": "Window height"}
        ],
        "default": "medium"
      },
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "Full width",
        "default": true
      },
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 10,
        "step": 0.2,
        "unit": "em",
        "label": "Section border radius",
        "default": 0
      },
      {
        "type": "range",
        "id": "section_padding_top",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Outer padding top",
        "default": 0
      },
      {
        "type": "range",
        "id": "section_padding_bottom",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Outer padding bottom",
        "default": 0
      },
      {
        "type": "header",
        "content": "Mobile Settings"
      },
      {
        "type": "radio",
        "id": "layout_mobile",
        "label": "Layout",
        "options": [
          {"value": "background","label": "Image as background"},
          {"value": "above","label": "Image at the top"},
          {"value": "below","label": "Image at the bottom"}
        ],
        "default": "above"
      },
      {
        "type": "select",
        "id": "section_height_mobile",
        "label": "Section/Image Height",
        "options": [
          {"value": "small","label": "Small"},
          {"value": "medium","label": "Medium"},
          {"value": "large","label": "Large"},
          {"value": "first_image","label": "Image height"},
          {"value": "window_height","label": "Window height"}
        ],
        "default": "medium"
      },
      {
        "type": "checkbox",
        "id": "full_width_mobile",
        "label": "Full width",
        "default": true
      },
      {
        "type": "range",
        "id": "border_radius_mobile",
        "min": 0,
        "max": 10,
        "step": 0.2,
        "unit": "em",
        "label": "Section border radius",
        "default": 0
      },
      {
        "type": "range",
        "id": "section_padding_top_mobile",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Outer padding top",
        "default": 0
      },
      {
        "type": "range",
        "id": "section_padding_bottom_mobile",
        "min": 0,
        "max": 100,
        "step": 10,
        "unit": "%",
        "label": "Outer padding bottom",
        "default": 0
      }
    ],
    "blocks": [
      {
        "type": "password_form",
        "name": "Password Form",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "field_label",
            "label": "Label",
            "default": "Store Password"
          },
          {
            "type": "header",
            "content": "Submit CTA"
          },
          {
            "type": "select",
            "id": "submit_style",
            "label": "Style",
            "options": [
              {"value": "btn","label": "Button"},
              {"value": "arrow","label": "Arrow"}
            ],
            "default": "btn"
          },
          {
            "type": "text",
            "id": "submit_label",
            "label": "Label",
            "default": "Enter"
          }
        ]
      },
      {
        "type": "content_title",
        "name": "Title",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Lorem ipsum dolor"
          },
          {
            "type": "checkbox",
            "id": "is_h1",
            "label": "This is the first title of the page (H1)"
          },
          {
            "type": "range",
            "id": "title_size",
            "min": -1,
            "max": 6,
            "step": 1,
            "unit": "h",
            "label": "Title size",
            "default": 1,
            "info": "Equivalent to the heading tags: 6 = <h6> (smallest), 1 = <h1> (largest), 0 and -1 are even larger."
          }
        ]
      },
      {
        "type": "content_text",
        "name": "Text",
        "settings": [
          {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>Lorem ipsum dolor sit amet, consectur adipiscing elit. Nunc eu eros augue. Cras tempus finibus mi, at aliquet orci vestibulum sit amet.</p>"
          },
          {
            "type": "select",
            "id": "text_style",
            "label": "Text style",
            "options": [
              {"value": "normal","label": "Body"},
              {"value": "subheading","label": "Subheading"},
              {"value": "small-label","label": "Small label"}
            ],
            "default": "normal"
          },
          {
            "type": "range",
            "id": "text_size",
            "min": 1,
            "max": 5,
            "step": 1,
            "unit": "p",
            "label": "Text size",
            "default": 3
          }
        ]
      },
      {
        "type": "content_button",
        "name": "Button",
        "settings": [
          {
            "type": "header",
            "content": "Primary Button"
          },
          {
            "type": "text",
            "id": "button",
            "label": "Button",
            "default": "Button"
          },
          {
            "visible_if": "{{ block.settings.button != blank }}",
            "type": "url",
            "id": "link",
            "label": "Link"
          },
          {
            "visible_if": "{{ block.settings.button != blank }}",
            "type": "select",
            "id": "cta_style",
            "label": "Style",
            "options": [
                {"value": "link", "label": "Link"},
                {"value": "btn", "label": "Button"},
                {"value": "btn v2", "label": "Button V2"}
            ],
            "default": "btn"
          },
          {
            "type": "header",
            "content": "Secondary Button"
          },
          {
            "type": "text",
            "id": "button_2",
            "label": "Button"
          },
          {
            "visible_if": "{{ block.settings.button_2 != blank }}",
            "type": "url",
            "id": "link_2",
            "label": "Link"
          },
          {
            "visible_if": "{{ block.settings.button_2 != blank }}",
            "type": "select",
            "id": "cta_style2",
            "label": "Style",
            "options": [
                {"value": "link", "label": "Link"},
                {"value": "btn", "label": "Button"},
                {"value": "btn v2", "label": "Button v2"}
            ],
            "default": "btn v2"
          }
        ]
      },
      {
        "type": "content_badge",
        "name": "Badge",
        "settings": [
          {
            "type": "text",
            "id": "badge",
            "label": "Badge",
            "default": "Limited"
          },
          {
            "visible_if": "{{ block.settings.badge != blank }}",
            "type": "select",
            "id": "style",
            "label": "Style",
            "options": [
              {"value": "pill", "label": "Pill"},
              {"value": "round", "label": "Round"}
            ],
            "default": "pill"
          }
        ]
      },
      {
        "type": "accordion_item",
        "name": "Accordion",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Lorem ipsum dolor sit amet?"
          },
          {
            "type": "range",
            "id": "title_size",
            "min": 1,
            "max": 3,
            "step": 1,
            "unit": "p",
            "label": "Title size",
            "default": 2,
            "info": "1 = larger. 2 = normal. 3 = smaller."
          },
          {
            "type": "select",
            "id": "title_style",
            "label": "Title style",
            "options": [
              {"value": "normal","label": "Body"},
              {"value": "heading-font","label": "Heading"},
              {"value": "subheading","label": "Subheading"},
              {"value": "small-label","label": "Small label"}
            ],
            "default": "normal"
          },
          {
            "type": "richtext",
            "id": "content",
            "label": "Text",
            "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus ut tellus nec mi tincidunt imperdiet eget vitae sapien. Integer massa velit, commodo at magna eget, semper vehicula quam. Morbi laoreet tellus at neque blandit, eu congue sem congue. Mauris dapibus est ut ipsum malesuada tincidunt. Curabitur tempus commodo suscipit. Sed eu blandit urna, at porttitor ligula. In maximus lobortis tellus.</p>"
          },
          {
            "type": "range",
            "id": "text_size",
            "min": 1,
            "max": 5,
            "step": 1,
            "unit": "p",
            "label": "Text size",
            "default": 3
          },
          {
            "type": "checkbox",
            "id": "accordion_border_top",
            "label": "Border Top",
            "default": false
          },
          {
            "type": "checkbox",
            "id": "accordion_border_bottom",
            "label": "Border Bottom",
            "default": true
          },
          {
            "type": "header",
            "content": "Image next to title"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "range",
            "id": "image_width",
            "min": 0,
            "max": 5,
            "step": 0.5,
            "unit": "em",
            "label": "Width",
            "default": 2
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "range",
            "id": "image_border_radius",
            "min": 0,
            "max": 10,
            "step": 0.2,
            "unit": "em",
            "label": "Border radius",
            "default": 0
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "checkbox",
            "id": "image_border",
            "label": "Border"
          }
        ]
      },
      {
        "type": "content_image",
        "name": "Image",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "url",
            "id": "link",
            "label": "Link"
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "range",
            "id": "width",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width (Desktop)",
            "default": 50
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "range",
            "id": "width_mobile",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width (Mobile)",
            "default": 100
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "range",
            "id": "border_radius",
            "min": 0,
            "max": 10,
            "step": 0.2,
            "unit": "em",
            "label": "Border radius",
            "default": 0
          },
          {
            "visible_if": "{{ block.settings.image != blank }}",
            "type": "checkbox",
            "id": "border",
            "label": "Border"
          },
          {
            "type": "header",
            "content": "Caption"
          },
          {
            "type": "richtext",
            "id": "caption",
            "label": "Caption"
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "select",
            "id": "caption_position",
            "label": "Position",
            "options": [
              {"value": "bottom","label": "Bottom"},
              {"value": "right","label": "Right"}
            ],
            "default": "bottom"
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "select",
            "id": "caption_style",
            "label": "Style",
            "options": [
              {"value": "normal","label": "Body"},
              {"value": "heading-font","label": "Heading"},
              {"value": "subheading","label": "Subheading"},
              {"value": "small-label","label": "Small label"}
            ],
            "default": "normal"
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "range",
            "id": "caption_size",
            "min": 1,
            "max": 5,
            "step": 1,
            "unit": "p",
            "label": "Size",
            "default": 4
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "range",
            "id": "caption_spacing",
            "min": 0,
            "max": 5,
            "step": 0.2,
            "unit": "rem",
            "label": "Spacing (Desktop)",
            "default": 1
          },
          {
            "visible_if": "{{ block.settings.caption != blank }}",
            "type": "range",
            "id": "caption_spacing_mobile",
            "min": 0,
            "max": 5,
            "step": 0.2,
            "unit": "rem",
            "label": "Spacing (Mobile)",
            "default": 1
          }
        ]
      },
      {
        "type": "content_video",
        "name": "Video",
        "settings": [
          {
            "type": "video",
            "id": "video_mp4",
            "label": "Video (MP4)"
          },
          {
            "type": "video_url",
            "id": "video_iframe",
            "label": "Video (Youtube/Vimeo)",
            "accept": ["youtube", "vimeo"]
          },
          {
            "type": "select",
            "id": "video_orientation",
            "label": "Video orientation",
            "options": [
              {"value": "landscape", "label": "Landscape/Horizontal"},
              {"value": "square", "label": "Square"},
              {"value": "portrait", "label": "Portrait/Vertical"}
            ],
            "default": "landscape"
          },
          {
            "type": "range",
            "id": "width",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width (Desktop)",
            "default": 50
          },
          {
            "type": "range",
            "id": "width_mobile",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width (Mobile)",
            "default": 100
          },
          {
            "type": "range",
            "id": "border_radius",
            "min": 0,
            "max": 10,
            "step": 0.2,
            "unit": "em",
            "label": "Border radius",
            "default": 0
          },
          {
            "type": "checkbox",
            "id": "border",
            "label": "Border"
          },
          {
            "type": "header",
            "content": "Caption"
          },
          {
            "type": "richtext",
            "id": "caption",
