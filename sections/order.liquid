{{ 'customer_portal.css' | asset_url | stylesheet_tag }}
<script src="{{ 'customer_portal.js' | asset_url }}" defer="defer"></script>
<div class="customer-portal-page scheme color-{{settings.customer_portal_color_scheme}}">
  <div class="container flex flex-wrap align-items-start">

    {%- render 'customer_portal_menu', template: template -%}

    <div class="flex-1 customer-portal-content">
      <h1>{{ 'account.order.title' | t: order_name: order.name}} {% if order.cancelled %}<span>{{ 'account.order.status_cancelled' | t }}</span>{% endif %}</h1>

      <div class="order-timeline">
        <p>
          <strong>{{ 'account.order.placed_at_label' | t }}</strong> {{ order.created_at | date: "%B %d, %Y %I:%M%p" }}
          {%- if order.cancelled -%}
            <br/><strong>{{ 'account.order.cancelled_at_label' | t }}</strong> {{ order.cancelled_at | date: "%B %d, %Y %I:%M%p" }}
          {%- endif -%}
        </p>
      </div>

      <div class="grid info">
        <div class="grid-item one-half small--one-whole">
          <h2 class="h3">{{ 'account.order.billing_address_title' | t }}</h2>
          <p>
            <strong>{{ order.billing_address.name }}</strong>
            {{ order.billing_address.company }}<br />
            {{ order.billing_address.street }}<br />
            {{ order.billing_address.city }}, {{ order.billing_address.province }}<br />
            {{ order.billing_address.country }} {{ order.billing_address.zip }}<br />
            {{ order.billing_address.phone }}
          </p>
          <p><strong>{{ 'account.order.payment_status_label' | t }} </strong><span class="status status-{{ order.financial_status }}">{{ order.financial_status }}</span></p>
        </div>
        {%- if order.shipping_address -%}
        <div class="grid-item one-half small--one-whole">
          <h2 class="h3">{{ 'account.order.shipping_address_title' | t }}</h2>
          <p>
            <strong>{{ order.shipping_address.name }}</strong>
            {{ order.shipping_address.company }}<br />
            {{ order.shipping_address.street }}<br />
            {{ order.shipping_address.city }}, {{ order.shipping_address.province }}<br />
            {{ order.shipping_address.country }} {{ order.shipping_address.zip }}<br />
            {{ order.shipping_address.phone }}
          </p>
          <p><strong>{{ 'account.order.fulfillment_status_label' | t }} </strong><span class="status status-{{ order.fulfillment_status }}">{{ order.fulfillment_status }}</span></p>
        </div>
        {%- endif -%}
      </div>

      <h2 class="h3">{{ 'account.order.order_summary_title' | t }}</h2>
      
      <div class="table products">
        <div class="small--hide">
          <div>{{ 'account.order.product_column_title' | t }}</div>
          <div>{{ 'account.order.price_column_title' | t }}</div>
          <div>{{ 'account.order.quantity_column_title' | t }}</div>
          <div>{{ 'account.order.total_column_title' | t }}</div>
        </div>
        {%- for line_item in order.line_items -%}
          <div class="{% cycle 'odd', 'even' %} {% if forloop.last %}last-product{% endif %}">
            <div>
              <div class="flex align-items-center small--align-items-start">
                <img class="lazyload" data-sizes="auto" src="{% render 'image_placeholder', image: line_item.image %}" data-srcset="{% render 'lazy_src', image: line_item.image %}" width="{{ line_item.image.width }}" height="{{ line_item.image.height }}" />
                <div>
                  <a href="{{ line_item.product.url }}" class="link">{{ line_item.title }}</a> 
                  {%- comment -%}
                  REF: FEATURE SELLING PLANS
                  {%- endcomment -%}
                  {%- if line_item.selling_plan_allocation.selling_plan != blank -%}
                    <div>{{ line_item.selling_plan_allocation.selling_plan.name }}</div>
                  {%- endif -%}
                  {%- if line_item.fulfillment -%}
                    <br />{%- assign fulfilledAt = line_item.fulfillment.created_at | date: "%b %d" -%}
                    {{ 'account.order.fullfilled_date_label' | t: fulfilled_at: fulfilledAt }}
                    {%- if line_item.fulfillment.tracking_number -%}
                      {%- if line_item.fulfillment.tracking_url != blank -%}
                      <br /><a href="{{ line_item.fulfillment.tracking_url }}" target="_blank" class="link">{{ line_item.fulfillment.tracking_company }} #{{ line_item.fulfillment.tracking_number}}</a>
                      {%- else -%}
                      <br />{{ line_item.fulfillment.tracking_company }} #{{ line_item.fulfillment.tracking_number}}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endif -%}
                  <div class="hide small--show">
                    <div><strong>{{ 'account.order.price_column_title' | t }}:</strong> {{ line_item.price | money }}</div>
                    <div><strong>{{ 'account.order.quantity_column_title' | t }}:</strong> {{ line_item.quantity }}</div>
                    <div><strong>{{ 'account.order.total_column_title' | t }}:</strong> {{ line_item.quantity | times: line_item.price | money }}</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="small--hide">{{ line_item.price | money }}</div>
            <div class="small--hide">{{ line_item.quantity }}</div>
            <div class="small--hide">{{ line_item.quantity | times: line_item.price | money }}</div>
          </div>
        {%- endfor -%}
        <div class="small--flex small--justify-content-between">
          <div class="small--hide"></div>
          <div>{{ 'account.order.subtotal_label' | t }}</div>
          <div class="small--hide"></div>
          <div>{{ order.subtotal_price | money }}</div>
        </div>
        {%- for shippingMethod in order.shipping_methods -%}
          <div class="small--flex small--justify-content-between">
            <div class="small--hide"></div>
            <div>{{ 'account.order.shipping_method_label' | t: shipping_title: shippingMethod.title }}</div>
            <div class="small--hide"></div>
            <div>{{ shippingMethod.price | money }}</div>
          </div>
        {%- endfor -%}
        {%- for tax_line in order.tax_lines -%}
          <div class="small--flex small--justify-content-between">
            <div class="small--hide"></div>
            {%- assign taxRate = tax_line.rate | times: 100 -%}
            {%- assign taxTitle = tax_line.title | append: ' ' | append: taxRate | append: '%' -%}
            <div>{{ 'account.order.tax_label' | t: tax_title: taxTitle }}</div>
            <div class="small--hide"></div>
            <div>{{ tax_line.price | money }}</div>
          </div>
        {%- endfor -%}
        <div class="small--flex small--justify-content-between">
          <div class="small--hide"></div>
          <div><strong>{{ 'account.order.total_label' | t }}</strong></div>
          <div class="small--hide"></div>
          <div><strong>{{ order.total_price | money }} {{ order.currency }}</strong></div>
        </div>   
      </div>

    </div>

  </div>

</div>

{% schema %}
  {
    "name": "Order",
    "class": "type-order"
  }
{% endschema %}