<div class="grid-item">
  {%- render 'richtext_blocks', blockType: 'newsletter_form', block: block -%}
</div>
{% schema %}
{
  "name": "Newsletter form",
  "tag": null,
  "presets": [
    {
      "name": "Newsletter form",
      "category": "Content",
      "blocks": [
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Success"
    },
    {
      "type": "richtext",
      "id": "success_message",
      "label": "Success",
      "default": "<p>Thanks for subscribing!</p>"
    },
    {
      "type": "header",
      "content": "Submit CTA"
    },
    {
      "type": "select",
      "id": "submit_style",
      "label": "Style",
      "options": [
        {"value": "btn","label": "Button"},
        {"value": "arrow","label": "Arrow"}
      ],
      "default": "btn"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Label",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Legal footnote"
    },
    {
      "type": "richtext",
      "id": "legal",
      "label": "Legal footnote"
    }
  ]
}
{% endschema %}