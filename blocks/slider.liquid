{% assign title = section.settings.title %}

{%- capture itemsHtml -%}
  {% content_for 'blocks' %}
{%- endcapture -%}
<div class="grid-item" id="shopify-section-{{ block.id }}">
  {%- capture multiItemHtml -%}
  {%- render 'section_multi_item_structure', section: block, cardType: 'product', itemsHtml: itemsHtml, title: title -%}
  {%- endcapture -%}
  {% comment %}
  {{ multiItemHtml | replace: 'section-grid', 'section-custom-grid' }}
  {% endcomment %}
  {{ multiItemHtml }}

</div>
    

{% schema %}
{
  "name": "Grid / Slider",
  "tag": null,
  "blocks": [{"type": "_slide"},{"type": "_product_cards"}],
  "presets": [
    {
      "name": "Grid / Slider",
      "category": "Layout",
      "blocks": [
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Head"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "visible_if": "{{ section.settings.eyebrow != blank }}",
      "type": "range",
      "id": "eyebrow_size",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "p",
      "label": "Eyebrow size",
      "default": 3
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Title of Grid or Slider"
    },
    {
      "visible_if": "{{ section.settings.title != blank }}",
      "type": "checkbox",
      "id": "is_h1",
      "label": "This is the first title of the page (H1)"
    },
    {
      "visible_if": "{{ section.settings.title != blank }}",
      "type": "range",
      "id": "title_size",
      "min": -1,
      "max": 6,
      "step": 1,
      "unit": "h",
      "label": "Title size",
      "default": 1,
      "info": "Equivalent to the heading tags."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "visible_if": "{{ section.settings.text != blank }}",
      "type": "range",
      "id": "text_size",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "p",
      "label": "Text size",
      "default": 3
    },
    {
      "type": "text",
      "id": "button",
      "label": "Button label"
    },
    {
      "visible_if": "{{ section.settings.button != blank }}",
      "type": "url",
      "id": "link",
      "label": "Button link"
    },
    {
      "visible_if": "{{ section.settings.button != blank }}",
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
          {"value": "link", "label": "Link"},
          {"value": "btn", "label": "Button"},
          {"value": "btn v2", "label": "Button V2"}
      ],
      "default": "btn"
    },
    {
      "visible_if": "{{ section.settings.button != blank }}",
      "type": "select",
      "id": "button_position",
      "label": "Button position",
      "options": [
        {"value": "top","label": "Top"},
        {"value": "bottom","label": "Bottom"}
      ],
      "default": "top"
    },
    {
      "type": "header",
      "content": "Items per view"
    },
    {
      "type": "paragraph",
      "content": "If the layout is set to Carousel, it indicates the items per slider page (allows decimals). If it's set to Grid, it indicates the items per row (decimals will be rounded down)."
    },
    {
      "type": "range",
      "id": "items_per_view_desktop",
      "min": 0,
      "max": 9,
      "step": 0.1,
      "unit": "un",
      "label": "Items per view (Desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "items_per_view_tablet",
      "min": 0,
      "max": 6,
      "step": 0.1,
      "unit": "un",
      "label": "Items per view (Tablet)",
      "default": 2.4
    },
    {
      "type": "range",
      "id": "items_per_view_mobile",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "unit": "un",
      "label": "Items per view (Mobile)",
      "default": 1.4
    },
    {
      "type": "header",
      "content": "Carousel settings"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "select",
      "id": "arrows_position",
      "label": "Arrows",
      "options": [
        {"value": "sides","label": "Sides"},
        {"value": "top","label": "Top"}
      ],
      "default": "top"
    },
    {
      "type": "select",
      "id": "carousel_width",
      "label": "Width (Desktop)",
      "options": [
        {"value": "full","label": "Full"},
        {"value": "container","label": "Container"},          
        {"value": "left","label": "Left container"}
      ],
      "default": "container"
    },
    {
      "type": "select",
      "id": "carousel_width_mobile",
      "label": "Width (Tablet/Mobile)",
      "options": [
        {"value": "full","label": "Full"},          
        {"value": "left","label": "Left container"}
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "carousel_autoplay",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay interval",
      "default": 0,
      "info": "0 = off"
    },
    {
      "type": "range",
      "id": "carousel_automove",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "%",
      "label": "Automove speed",
      "default": 0,
      "info": "0 = off"
    },

    {
      "type": "header",
      "content": "Section settings"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "select",
      "id": "head_position",
      "label": "Header position (Desktop)",
      "options": [
        {"value": "top","label": "Top"},
        {"value": "left","label": "Left"}
      ],
      "default": "top"
    },
    {
      "type": "range",
      "id": "head_width",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "%",
      "label": "Header width (Desktop)",
      "default": 20,
      "info": "When the head is on the left."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {"value": "carousel","label": "Carousel"},
        {"value": "grid","label": "Grid"}
      ],
      "default": "carousel"
    },
    {
      "type": "radio",
      "id": "grid_collapsible",
      "label": "Show 'View All' button in grid mode",
      "options": [
        {"value": "desktop","label": "Desktop only"},
        {"value": "mobile","label": "Mobile only"},
        {"value": "desktop_mobile","label": "Desktop and mobile"},
        {"value": "none", "label": "No"}
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "items_spacing_desktop",
      "min": 0,
      "max": 500,
      "step": 50,
      "unit": "%",
      "label": "Items spacing (Desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "items_spacing_mobile",
      "min": 0,
      "max": 500,
      "step": 50,
      "unit": "%",
      "label": "Items spacing (Mobile)",
      "default": 100
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Align (title, text, button, dots)",
      "options": [
        {"value": "left","label": "Left"},
        {"value": "center","label": "Center"},
        {"value": "right","label": "Right"}
      ],
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "content_color_scheme",
      "label": "Content color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 10,
      "step": 0.2,
      "unit": "em",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding Desktop"
    },
    {
      "type": "range",
      "id": "text_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Inner padding (Desktop)",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Outer padding top (Desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Outer padding bottom (Desktop)",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding Mobile"
    },
    {
      "type": "range",
      "id": "text_padding_mobile",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Inner padding (Mobile)",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Outer padding top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Outer padding bottom (Mobile)",
      "default": 0
    }
  ]
}
{% endschema %}
