<style>
  #shopify-section-{{section.id}} .block-{{block.id}} {
    --items-spacing: calc(var(--grid-gap) * {{block.settings.items_spacing_desktop | divided_by: 100.00}});
    --image-width: {{block.settings.image_width}}%;
    --image-height: calc(100% / {{block.settings.image_height | replace: 'auto', block.settings.image1.aspect_ratio | default: 1  }});
    --image-border-radius: {{block.settings.image_border_radius | replace: '10', '1000'}}em;
    --image-offset: 0rem;
    --card-border-radius: {{block.settings.card_border_radius}}em;
    --card-padding: {{block.settings.card_padding_desktop}}%;
    --card-separation: max({{block.settings.card_padding_desktop}}%, 1em);
    --items-per-row: {{block.settings.items_per_row_desktop}};
    --card-title-font-size: {{block.settings.card_title_font_size}}%;
    --card-title-weight: {{block.settings.card_title_weight}};
    --card-title-text-transform: {{block.settings.card_title_text_transform}};
    --card-title-letter-spacing: {{block.settings.card_title_letter_spacing | divided_by: 10.00}}em;
  }
  @media (max-width: {{settings.breakpoint_tablet}}) {
    #shopify-section-{{section.id}} .block-{{block.id}} {
      --items-per-row: {{block.settings.items_per_row_tablet}};
    }
  }
  @media (max-width: {{settings.breakpoint_mobile}}){
    #shopify-section-{{section.id}} .block-{{block.id}} {
      --items-spacing: calc(var(--grid-gap) * {{block.settings.items_spacing_mobile | divided_by: 100.00}});
      --items-per-row: {{block.settings.items_per_row_mobile}};
      --card-padding: {{block.settings.card_padding_mobile}}%;
      --card-separation: max({{block.settings.card_padding_mobile}}%, 1em);
    }
  }
  #shopify-section-{{section.id}} .block-{{block.id}} .image-position-left {align-items: center;}
  #shopify-section-{{section.id}} .block-{{block.id}} > .grid {--grid-gap: var(--items-spacing); margin-bottom: calc(var(--items-spacing) * -1);}
  #shopify-section-{{section.id}} .block-{{block.id}} > .grid > .grid-item {width: calc(100% / var(--items-per-row)); margin-bottom: var(--items-spacing);}
</style>
{{ 'custom_items.css' | asset_url | stylesheet_tag }}

{%- assign imagePosition = block.settings.image_position -%}

{%- for i in (1..4) -%}
  {%- liquid 
    assign image = 'image' | append: i
    assign title = 'title' | append: i
    assign text = 'text' | append: i
    assign button = 'button' | append: i
    assign link = 'link' | append: i
  -%}
  {%- if block.settings[title] != blank or block.settings[image] != blank or block.settings[text] != blank -%}
    <div class="grid-item">
      {{ '<' }}{%- if block.settings[button] == blank and block.settings[link] != blank -%}a href="{{block.settings[link]}}" {% if block.settings[link] contains 'http:// ' %}target="_blank"{% endif %}{%- else -%}div{%- endif %} class="custom-card no-highlight-hover scheme color-{{block.settings.cards_color_scheme}} text-{{block.settings.card_text_align}} image-position-{{imagePosition}} border-{{block.settings.card_border}} {% if block.settings.card_border %}scheme-border-box{% endif %} image-padding-{{block.settings.image_padding}} same-scheme-{%- if section.settings.content_color_scheme == block.settings.cards_color_scheme -%}true{%- else -%}false{%- endif -%}" expandable-false">
        {%- capture imageHtml -%}
          {%- if block.settings[image] != blank -%}
            <div class="image-container {% if block.settings.image_border %}scheme-border-box{% endif %} shadow-{{block.settings.image_shadow}}">
              <div class="img ease-animation-slow lazyload" data-bgset="{% render 'lazy_src', image: block.settings[image]  %}" {% if block.settings[image].presentation.focal_point != blank %}style="background-position: {{block.settings[image].presentation.focal_point}};"{% endif %}></div>
            </div>
          {%- endif -%}
        {%- endcapture -%}
        {%- if imagePosition == 'top' or imagePosition == 'left' -%}
          {{imageHtml}}
        {%- endif -%}

          {%- capture topHtml -%}
            {%- if block.settings[title] != blank -%}
              {%- assign hasTop = true -%}
              <div class="title {{block.settings.card_title_font_family}}">
                {{ block.settings[title] | replace: '[br]', '<br aria-hidden="true" />' | replace: '[hi]', '<span class="highlight">' | replace: '[/hi]', '</span>' }}
              </div>
            {%- endif -%}
          {%- endcapture -%}

          {%- capture bottomInfo -%}
            {%- if block.settings[text] != blank  -%} 
              {%- assign hasBottom = true -%}
              <div class="text {{block.settings.card_text_size | prepend: 'p'}}">
                {{ block.settings[text] }}
              </div>
            {%- endif -%}
            {%- if block.settings[author] != blank -%} 
              {%- assign hasBottom = true -%}
              <div class="text small-label">{{ block.settings[author] }}</div>
            {%- endif -%}
            {%- if block.settings[button] != blank -%}
              {%- assign hasBottom = true -%}
              <div class="btn-wrap">
                {%- assign linkIcon = blank -%}
                {%- if block.settings.cta_style contains 'link' and settings.links_arrow != 'none' -%}
                  {%- capture linkIcon -%}{%- render 'icons', icon: settings.links_arrow -%}{%- endcapture -%}
                {%- endif -%}
                <a href="{{ block.settings[link] }}" {% if block.settings[link] contains 'http:// ' %}target="_blank"{% endif %} class="cta {{block.settings.cta_style}} {{block.settings.cta_size}}">
                  {{ block.settings[button] }}{{linkIcon}}
                </a>
              </div>
            {%- endif -%}
          {%- endcapture -%}

        {%- if hasTop or hasBottom -%}
          <div class="info">

            {{topHtml}}

            {%- if hasBottom -%}
              <div class="info-bottom ignore-slide-tabindex">
                <div class="info-bottom-inner">
                  {{bottomInfo}}                
                </div>
              </div>
            {%- endif -%}

          </div>
        {%- endif -%}

        {%- if imagePosition == 'bottom' or imagePosition == 'right' -%}
          {{imageHtml}}
        {%- endif -%}

      {{ '</' }}{%- if block.settings[button] == blank and block.settings[link] != blank -%}a{%- else -%}div{%- endif -%}{{ '>' }}
    </div>
  {%- endif -%}
{%- endfor -%}