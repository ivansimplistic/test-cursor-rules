{%- if data == "shop" -%}
<!-- SCHEMA MARKUP -->
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Website",
        "url": "{{shop.url}}",
        "potentialAction": {
            "@type": "SearchAction",
            "target": "{{shop.url}}{{ routes.search_url }}?q={query}",
            "query-input": "required name=query"
        }
    }
</script>
<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "{{shop.name}}",
        "url": "{{shop.url}}",
        "description": "{{shop.description | strip_html | strip_newlines | escape}}",
        {%- if settings.seo_logo -%}
        "logo": {{ settings.seo_logo | image_url: width: 500 | prepend: "https:" | json }},
        {%- endif -%}
        {%- if settings.seo_social_image -%}
        "image": {{ settings.seo_social_image | image_url: width: 500 | prepend: "https:" | json }},
        {%- endif -%}
        "sameAs": [{%- if settings.social_twitter != '' -%}"{{ settings.social_twitter }}",{%- endif -%}{%- if settings.social_pinterest != '' -%}"{{ settings.social_pinterest }}",{%- endif -%}{%- if settings.social_linkedin != '' -%}"{{ settings.social_linkedin }}",{%- endif -%}{%- if settings.social_vimeo != '' -%}"{{ settings.social_vimeo }}",{%- endif -%}{%- if settings.social_youtube != '' -%}"{{ settings.social_youtube }}",{%- endif -%}{%- if settings.social_tiktok != '' -%}"{{ settings.social_tiktok }}",{%- endif -%}{%- if settings.social_facebook != '' -%}"{{ settings.social_facebook }}",{%- endif -%}{%- if settings.social_instagram != '' -%}"{{ settings.social_instagram }}"{%- endif -%}],
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "{{shop.address.street}}",
            "addressLocality": "{{shop.address.city}}",
            "addressRegion": "{{shop.address.province}}",
            "postalCode": "{{shop.address.zip}}",
            "addressCountry": "{{shop.address.country}}"
        },
        "telephone": "{{shop.phone}}"
    }
</script>
{%- endif -%}
{%- if data == "product" -%}
<!-- SCHEMA MARKUP PRODUCT -->
<script type="application/ld+json">
      {
          "@context": "http://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
              {
                  "@type": "ListItem",
                  "position": 1,
                  "item": {
                      "@type": "Website",
                      "@id": "{{shop.url}}",
                      "name": "{{shop.name}}"
                  }
              },
              {%- if collection.url -%}
              {
                  "@type": "ListItem",
                  "position": 2,
                  "item": {
                      "@type": "CollectionPage",
                      "@id": "{{shop.url}}{{collection.url}}",
                      "name": "{{collection.title | escape}}"
                  }
              },
              {%- endif -%}
              {
                  "@type": "ListItem",
                  "position": {%- if collection.url -%}3{%- else -%}2{%- endif -%},
                  "item": {
                      "@type": "WebPage",
                      "@id": "{{shop.url}}{{collection.url}}{{product.url}}",
                      "name": "{{product.title | escape}}"
                  }
              }
          ]
      }
</script>
  {%- render 'product_microdata', currentProduct: product -%}
{%- endif -%}
{%- if data == "collection" -%}
<!-- SCHEMA MARKUP COLLECTION -->
<script type="application/ld+json">
      {
          "@context": "http://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
              {
                  "@type": "ListItem",
                  "position": 1,
                  "item": {
                      "@type": "Website",
                      "@id": "{{shop.url}}",
                      "name": "{{shop.name}}"
                  }
              },
              {
                  "@type": "ListItem",
                  "position": 2,
                  "item": {
                      "@type": "CollectionPage",
                      "@id": "{{shop.url}}{{collection.url}}",
                      "name": "{{collection.title | escape}}"
                  }
              }
          ]
      }
</script>
<script type="application/ld+json">
    [
        {
            "@context" : "http://schema.org",
            "@type": "CollectionPage",
            "name": "{{collection.title | escape}}",
            "url": "{{shop.url}}{{collection.url}}",
            "description": "{{collection.description | strip_html | strip_newlines | escape}}",
            "image": "https:{{collection.image | image_url: width: 1000, height: 1000}}"
        }
    ]
</script>
<script type="application/ld+json">
[
  {
    "@context":"http://schema.org",
    "@type":"ItemList",
    "name":"{{collection.title | escape}}",
    "url":"{{shop.url}}{{collection.url}}",
    "description":"{{collection.description | strip_html | strip_newlines | escape}}",
    "image":"https:{{collection.image | image_url: width: 1000, height: 1000}}",
    "mainEntityOfPage":{
      "@type":"CollectionPage",
      "@id":"{{shop.url}}{{collection.url}}"
    },
    "itemListElement":[
      {%- for prod in collection.products -%}
      {"@type":"ListItem","name":"{{prod.title | escape}}","url":"{{shop.url}}{{prod.url}}","position":{{forloop.index}}}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
]
</script>
{%- endif -%}
{%- if data == "blog" -%}
<!-- SCHEMA MARKUP BLOG -->
<script type="application/ld+json">
      {
          "@context": "http://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
              {
                  "@type": "ListItem",
                  "position": 1,
                  "item": {
                      "@type": "Website",
                      "@id": "{{shop.url}}",
                      "name": "{{shop.name}}"
                  }
              },
              {
                  "@type": "ListItem",
                  "position": 2,
                  "item": {
                      "@type": "Blog",
                      "@id": "{{shop.url}}{{blog.url}}",
                      "name": "{{blog.title | escape}}"
                  }
              }
          ]
      }
</script>
<script type="application/ld+json">
    {
        "@context" : "http://schema.org",
        "@type" : "Blog",
        "about": "{{shop.description | strip_html | strip_newlines | escape}}",
        "keywords": "{%- for tag in blog.tags -%}{{tag}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}",
        "name": "{{blog.title | escape}}",
        "url": "{{shop.url}}{{blog.url}}",
        "blogPosts": [
           {%- for article in blog.articles -%}
            {
                "@context" : "http://schema.org",
                "@type" : "BlogPosting",
                "headline" : "{{article.title | escape}}",
                "mainEntityOfPage" : "{{shop.url}}{{article.url}}",
                "image": {
                    "@type": "ImageObject",
                    "url": "https:{{article.image | image_url: width: 1000, height: 1000}}"
                },
                "url" : "{{shop.url}}{{article.url}}",
                "datePublished": "{{ article.published_at | date: '%Y-%m-%d %k:%M:%S %z'}}",
                "dateModified" : "{{ article.updated_at | date: '%Y-%m-%d %k:%M:%S %z'}}",
                "dateCreated": "{{ article.created_at | date: '%Y-%m-%d %k:%M:%S %z'}}",
                "author": {
                    "@type": "Person",
                    "name": "{{article.author}}"
                },
                "publisher": {
                    "@type": "Organization",
                    "name": "{{shop.name}}"
                }
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
    }
</script>
{%- endif -%}
{%- if data == "article" -%}
<!-- SCHEMA MARKUP ARTICLE -->
<script type="application/ld+json">
      {
          "@context": "http://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
              {
                  "@type": "ListItem",
                  "position": 1,
                  "item": {
                      "@type": "Website",
                      "@id": "{{shop.url}}",
                      "name": "{{shop.name}}"
                  }
              },
              {
                  "@type": "ListItem",
                  "position": 2,
                  "item": {
                      "@type": "Blog",
                      "@id": "{{shop.url}}{{blog.url}}",
                      "name": "{{blog.title | escape}}"
                  }
              },
              {
                  "@type": "ListItem",
                  "position": 3,
                  "item": {
                      "@type": "Article",
                      "@id": "{{shop.url}}{{article.url}}",
                      "name": "{{article.title | escape}}"
                  }
              }
          ]
      }
</script>
<script type="application/ld+json">
    {
        "@context" : "http://schema.org",
        "@type" : "Article",
        "about": "{%- if article.excerpt.size > 0  -%}{{article.excerpt | strip_html}}{%- else -%}{{article.content | strip_html | strip_newlines | escape | truncatewords: 100}}{%- endif -%}",
        "keywords": "{%- for tag in article.tags -%}{{tag}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}",
        "headline": "{{article.title | escape}}",
        "mainEntityOfPage" : "{{shop.url}}{{article.url}}",
        "image": {
            "@type": "ImageObject",
            "url": "https:{{article.image | image_url: width: 1000, height: 1000}}"
        },
        "url": "{{shop.url}}{{article.url}}",
        "datePublished": "{{ article.published_at | date: '%Y-%m-%d %k:%M:%S %z'}}",
        "dateModified" : "{{ article.updated_at | date: '%Y-%m-%d %k:%M:%S %z'}}",
        "dateCreated": "{{ article.created_at | date: '%Y-%m-%d %k:%M:%S %z'}}",
        "articleBody": "{{article.content | strip_html | strip_newlines | escape}}",
        "author": {
            "@type": "Person",
            "name": "{{article.author}}"
        },
        "publisher": {
            "@type": "Organization",
            "name": "{{shop.name}}"
        }
    }
</script>
{%- endif -%}