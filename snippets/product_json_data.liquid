{% doc %}
  Generates a JSON script with comprehensive product data required by product components including media, variants, options, and selling plan groups.
  
  This snippet handles product merge functionality when enabled, combining variants from linked products. It also supports combined listing mode by providing enhanced options_with_values data with availability and product URL information.
  
  @param {object} productObject - The product object containing all product data
  @param {boolean} [isMain] - Whether this is the main product page
  @param {boolean} [includeSellingPlans] - Whether to include selling plan data
  
  @example
  {% render 'product_json_data', 
    productObject: product, 
    isMain: true, 
    includeSellingPlans: true %}
  
  @example
  {% render 'product_json_data', 
    productObject: product %}
{% enddoc %}

{%- comment -%}
  Usage: render 'product_json_data', productObject: product, includeSellingPlans: true/false
  Generates a JSON script with data required by our product components  (media, variants, options, sellingPlanGroups...)
  For combined listing, the options_with_values property needs 'available' and 'product_url' properties, which is not available in the variants data.
{%- endcomment -%}

{% assign isMain = isMain | default: false %}

{%- liquid
  assign includeSellingPlans = includeSellingPlans | default: false
  assign allVariants = productObject.variants
  assign allSellingPlanGroups = productObject.selling_plan_groups
  comment 
  REF: Product Merge 
  endcomment 
  if settings.merge_variants_support
    if settings.merge_variants_in_product_cards or isMain
      for linkedProduct in productObject.metafields.custom.linked_products_group.value.products.value
        unless productObject.id == linkedProduct.id
          assign allVariants = allVariants | concat: linkedProduct.variants
          if includeSellingPlans
            assign allSellingPlanGroups = allSellingPlanGroups | concat: linkedProduct.selling_plan_groups
          endif
        endunless
      endfor
    endif
  endif
-%}

{%- capture variantsData -%}
  {%- for variant in allVariants -%}
    {%- if forloop.index > 1 -%},{%- endif -%}
    {
      "id": {{ variant.id }},
      "title": {{ variant.title | json }},
      "available": {{ variant.available }},
      "price": {{ variant.price }},
      "compare_at_price": {{ variant.compare_at_price | default: 'null' }},
      "featured_media": {{ variant.featured_media | json }},
      {% if includeSellingPlans %}
        "selling_plan_allocations": [{% for alloc in variant.selling_plan_allocations %}{%- if forloop.index > 1 -%},{%- endif -%}
          {"compare_at_price": {{ alloc.compare_at_price }}, "price": {{ alloc.price }}, "selling_plan_group_id": "{{ alloc.selling_plan_group_id }}", "selling_plan_id": "{{ alloc.selling_plan.id }}" }
        {% endfor %}],
      {% endif %}
      "product_url": "{{ variant.url }}",
      "product_id": {{ variant.product.id }},
      "sku": {{ variant.sku | json }},
      "options": [
        {%- for option in variant.options -%}
          {%- if forloop.index > 1 -%},{%- endif -%}{{ option | json }}
        {%- endfor -%}
      ]
      {%- comment -%} UNUSED variant properties
      ,
      "inventory_management": {{ variant.inventory_management | json }},
      "quantity_rule": {{ variant.quantity_rule | json }},
      "taxable": {{ variant.taxable }},
      "weight": {{ variant.weight }},
      "requires_shipping": {{ variant.requires_shipping }},
      "requires_selling_plan": {{ variant.requires_selling_plan }}
      {%- endcomment -%}
    }
  {%- endfor -%}
{%- endcapture -%}

<script type="application/json" data-product-json="">
{
  "is_product_main": {{ isMain | json }},
  {% if productObject.metafields.custom.linked_products_group.value.products != blank %}"is_product_merge": true,{% endif %}
  "product_id": {{ productObject.id }},
  "product_url": "{{ productObject.url }}",
  "variants": [{{ variantsData }}],
  {% if settings.combined_products_support_mode != 'disabled' %}  
    "options_with_values": [
    {%- for option in productObject.options_with_values -%}{% if forloop.index > 1 %},{% endif %}
      {
      "name": {{ option.name | json }},
      "values": [
        {%- for value in option.values -%}{% if forloop.index > 1 %},{% endif %}
        {
        "value": {{ value | json }},
        {% if value.product_url %}"product_url": "{{ value.product_url }}",{% endif %}
        "available": {{ value.available }}
        }
        {%- endfor -%}]
      }
    {%- endfor -%}]
  {% else %}
    "options_with_values": {{ productObject.options_with_values | json }}
  {% endif %}
  
  {%- if includeSellingPlans and productObject.selling_plan_groups.size > 0 -%}
    , "sellingPlanGroups": {{ allSellingPlanGroups | json }},
    "requiresSellingPlan": {{ productObject.requires_selling_plan | json }}
  {%- endif -%}
} 
</script>