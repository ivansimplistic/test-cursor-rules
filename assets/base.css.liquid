{% assign schemeClasses = ':root,' %}
{% for scheme in settings.color_schemes %}
  {% assign schemeClasses = schemeClasses | append: ', .color-' | append: scheme.id %}
  {%- capture schemeVariables -%}
    --scheme-background-color: {{ scheme.settings.background | append: '' }};
    {% if scheme.settings.background_gradient != empty %}
      --scheme-background-gradient: {{ scheme.settings.background_gradient | append: '' }};
    {% else %}
      --scheme-background-gradient: {{ scheme.settings.background | append: '' }};
    {% endif %}
    --scheme-headings-color: {{ scheme.settings.headings | append: '' }};
    --scheme-text-color: {{ scheme.settings.text | append: '' }};
    --scheme-borders-color: {{ scheme.settings.global_borders }};
    --scheme-highlights: {{ scheme.settings.highlights | append: '' }};
    --scheme-buttons-background: {{ scheme.settings.buttons_background | append: '' }};
    --scheme-buttons-label: {{ scheme.settings.buttons_label | append: '' }};
    --scheme-buttons-border: {{ scheme.settings.buttons_border | append: '' }};
    --scheme-buttons-background-hover: {{ scheme.settings.buttons_background_hover | append: '' }};
    --scheme-buttons-label-hover: {{ scheme.settings.buttons_label_hover | append: '' }};
    --scheme-buttons-border-hover: {{ scheme.settings.buttons_border_hover | append: '' }};
    --scheme-buttons-background2: {{ scheme.settings.buttons_background2 | append: '' }};
    --scheme-buttons-label2: {{ scheme.settings.buttons_label2 | append: '' }};
    --scheme-buttons-border2: {{ scheme.settings.buttons_border2 | append: '' }};
    --scheme-buttons-background-hover2: {{ scheme.settings.buttons_background_hover2 | append: '' }};
    --scheme-buttons-label-hover2: {{ scheme.settings.buttons_label_hover2 | append: '' }};
    --scheme-buttons-border-hover2: {{ scheme.settings.buttons_border_hover2 | append: '' }};
    --scheme-fields-background-color: {{ scheme.settings.fields_background }};
    --scheme-fields-border-color: {{ scheme.settings.fields_border }};
    --scheme-fields-label-color: {{ scheme.settings.fields_label | append: '' }};
    --scheme-fields-autofill-background-color: var(--scheme-fields-background-color);
    --scheme-fields-autofill-text-color: var(--scheme-fields-label-color);
    --scheme-errors-color: {{ scheme.settings.errors | append: '' }};
    --scheme-success-color: {{ scheme.settings.success | append: '' }};
    --scheme-carousel-arrows-background: {{ scheme.settings.carousel_arrows_background }};
    --scheme-carousel-arrows-border: {{ scheme.settings.carousel_arrows_border }};
    --scheme-carousel-arrows-label: {{ scheme.settings.carousel_arrows_label | append: '' }};
    --scheme-carousel-dots-off: {{ scheme.settings.carousel_dots_off }};
    --scheme-carousel-dots-on: {{ scheme.settings.carousel_dots_on }};
    --scheme-badges-background: {{ scheme.settings.badges_background | append: '' }};
    --scheme-badges-border: {{ scheme.settings.badges_border | append: '' }};
    --scheme-badges-label: {{ scheme.settings.badges_label | append: '' }};
    --scheme-tabs-background-on: {{ scheme.settings.tabs_background_on | append: '' }};
    --scheme-tabs-border-on: {{ scheme.settings.tabs_border_on | append: '' }};
    --scheme-tabs-label-on: {{ scheme.settings.tabs_label_on | append: '' }};
    --scheme-tabs-background-off: {{ scheme.settings.tabs_background_off | append: '' }};
    --scheme-tabs-border-off: {{ scheme.settings.tabs_border_off | append: '' }};
    --scheme-tabs-label-off: {{ scheme.settings.tabs_label_off | append: '' }};
    --scheme-tabs-border-on2: {{ scheme.settings.tabs_border_on2 | append: '' }};
    --scheme-tabs-label-on2: {{ scheme.settings.tabs_label_on2 | append: '' }};
    --scheme-tabs-border-off2: {{ scheme.settings.tabs_border_off2 | append: '' }};
    --scheme-tabs-label-off2: {{ scheme.settings.tabs_label_off2 | append: '' }};
    
  {% endcapture %}
  {% if forloop.first %}:root, {% endif %}.color-{{ scheme.id }} {
    {{schemeVariables}}
  }
  @media (min-width: {{settings.breakpoint_tablet | plus: 0.001}}em){
    .large--color-{{ scheme.id }} {
      {{schemeVariables}}
    }
  }
  @media (max-width: {{settings.breakpoint_tablet}}){
    .medium-down--color-{{ scheme.id }} {
      {{schemeVariables}}
    }
  }
{% endfor %}


:root {
  --animation-speed-fast: .2s;
  --animation-speed-medium: .35s;
  --animation-speed-slow: .5s;
  --header-change-animation-speed: var(--animation-speed-fast);
  --container-width: {{settings.container_width | divided_by: 10 }}rem;
  --slide-in-modal-width: 40rem;
  --slide-in-modal-padding: 2.2rem;
  --font-body-scale: {{ settings.body_scale | divided_by: 100.0 }};
  --fields-padding-vertical: {{settings.fields_padding_vertical}}rem;
  --fields-padding-horizontal: {{settings.fields_padding_horizontal}}rem;
  --floating-box-shadow: 0 0 5px rgba(0,0,0,.2);
  --keen-arrows-size: {{settings.carousel_arrows_size}}rem; 
  --keen-arrows-width: 1.5em;
  --product-card-info-height: {% if settings.product_card_swatches %}8.2rem{% else %}2.5rem{% endif %};
  --icons-thickness: {{settings.icons_thickness}}%;
  --icons-round: {{settings.icons_round | replace: true, 'round' | replace: false, 'miter'}};
  --tabs-margin: 0.5em;
  --vh: 1vh;
  --100vh: 100vh;
  --visible-height: calc(var(--100vh) - var(--header-offset, 0px));
  --product-swatches-size: 2.7em;
}
#main-content section:first-of-type {
  --100vh: calc(var(--vh) * 100);
  --visible-height: calc(var(--100vh) - var(--initial-header-total-height));
}
@media (min-width: {{settings.container_width | plus: 200 | divided_by: 16}}rem){
  :root {
    --container-width: calc({{settings.container_width}} * 100 / {{settings.container_width | plus: 200}} * 1vw);
  }
}
@media (min-width: {{settings.breakpoint_tablet | plus: 0.001}}em) {
  :root {
    --container-padding: {{settings.container_padding}}rem;
    --grid-gap: {{settings.grid_gap}}rem;
    --global-sections-padding: {{settings.sections_padding}}rem;
    --font-heading-scale: {{ settings.heading_scale | times: 1.0 | divided_by: settings.body_scale }};
    --subheading-size: {{settings.subheading_scale | append: '%'}};
    --small-label-size: {{settings.small_label_scale | append: '%'}};
    --links-size: {{settings.links_scale | append: '%'}};
  }
}
@media (max-width: {{settings.breakpoint_tablet}}) {
  :root {
    --container-padding: {{settings.container_padding_tablet}}rem;
    --grid-gap: {{settings.grid_gap}}rem;
    --global-sections-padding: {{settings.sections_padding_mobile}}rem;
    --font-heading-scale: {{ settings.heading_scale | times: 0.85 | divided_by: settings.body_scale }};
    --subheading-size: {{settings.subheading_scale_mobile | append: '%'}};
    --small-label-size: {{settings.small_label_scale_mobile | append: '%'}};
    --links-size: {{settings.links_scale_mobile | append: '%'}};
  }
}
@media (max-width: {{settings.breakpoint_mobile}}) {
  :root {
    --container-padding: {{settings.container_padding_mobile}}rem;
    --grid-gap: {{settings.grid_gap_mobile}}rem;
    --slide-in-modal-width: 100%;
    --font-body-scale: {{ settings.body_scale_mobile | divided_by: 100.0 }};
    --font-heading-scale: {{ settings.heading_scale_mobile | times: 1.0 | divided_by: settings.body_scale_mobile }};
  }
}

/* 
******************** LAZYLOAD effect ********************
*/
.lazyload, .lazyloading {opacity: 0.01;}
.lazyloaded {opacity: 1;}
html.load .lazyloaded {transition: opacity var(--animation-speed-slow) ease-out;}

/* 
******************** RESET ********************
*/
* {-moz-box-sizing: border-box; -webkit-box-sizing: border-box; box-sizing: border-box; text-underline-offset: {{settings.links_underline_offset | divided_by: 100.00}}em;}
html {padding-bottom: 0 !important;} /* Overrides Shopify's preview bar padding */
html, body {margin: 0; padding: 0; border: 0;}
a {color: inherit; text-decoration: none;}
p a, li a {text-decoration: underline;}
img,
video {display: block; width: 100%; height: initial; border: none;}
table {width: 100%; border-collapse: collapse; vertical-align: middle; border-spacing: 0;}
input, select, button {vertical-align: middle;}
input::-ms-clear {display: none;}
select, textarea, input[type="button"], input[type='text'],input[type='email'], input[type='number'], input[type='search'], input[type='date'], input[type="tel"], input[type="phone"], input[type='password'], button {font: inherit; color: inherit; appearance:none; -moz-appearance:none; -webkit-appearance:none; border: 0; padding: 0; border-radius: 0; background: transparent; line-height: normal;}
textarea {line-height: inherit; resize: none; min-height: 120px;}
button, label, select {cursor: pointer;}
select::-ms-expand {display: none;}
select {text-overflow: ellipsis;}
fieldset, legend {margin: 0; padding: 0; border: 0; box-shadow: none; font: inherit; color: inherit; appearance:none; -moz-appearance:none; -webkit-appearance:none;}

svg.icon {stroke-width: var(--icons-thickness); display: block; stroke-linecap: var(--icons-round); stroke-linejoin: var(--icons-round); width: 1em; height: 1em; font-size: 1em; line-height: 1; overflow: visible;}
svg.icon path {stroke: none; fill: none; -webkit-transition: all var(--animation-speed-fast) ease-out; -moz-transition: all var(--animation-speed-fast) ease-out; -o-transition: all var(--animation-speed-fast) ease-out; -ms-transition: all var(--animation-speed-fast) ease-out; transition: all var(--animation-speed-fast) ease-out;}
svg.icon path.stroke {stroke: var(--scheme-icons-color);} 
svg.icon path.fill {fill: var(--scheme-icons-color);}
svg.icon:focus {outline: none;}

table {font-size: 0.9em; box-shadow: inset 0 0 0 1px var(--scheme-borders-color) !important; border-radius: 0.4em; margin-bottom: 1.5rem;}
table:last-child {margin-bottom: 0;}
table th,
table td {vertical-align: top; min-width: 12em; border: 1px solid var(--scheme-borders-color); border-top: 0; padding: 0.5em 0.8em 0.4em;}
table th:first-child, td:first-child {border-left: 0;}
table th:last-child, td:last-child {border-right: 0;}
table th {background: rgba(0,0,0,0.05);}
table tr:nth-child(even) td {background: rgba(0,0,0,0.01);}
table tr:last-child td {border-bottom: 0;}
@media (max-width: {{settings.breakpoint_tablet}}){
  table {display: block; overflow-x: auto;}
}

.type-page-main .richtext-wrap h2:not(:first-child), .type-page-main .richtext-wrap h3, .type-page-main .richtext-wrap h4, .type-page-main .richtext-wrap h5, .type-page-main .richtext-wrap h6 {margin-top: 1.2em;}
.type-page-main .richtext-wrap {--font-heading-scale: 0.7;}


