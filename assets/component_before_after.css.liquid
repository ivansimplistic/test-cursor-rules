before-after {display: block; position: relative; overflow: hidden; height: 100%; --slide-bar-width: 40px; --scheme-icons-color: var(--overlay-color);}
before-after:not(.initialized) *:not(.img) {display: none;}
before-after .captions {color: var(--overlay-color); position: absolute; top: 0; left: 0; width: 100%; display: flex; justify-content: space-between; padding: 0.5em 1em;}
before-after .img2 {position: absolute; top: 0; bottom: 0; right: 0; width: 100%; height: 100%; object-fit: cover; object-position: right;}
before-after .slider {position: absolute; bottom: 0; width: calc(100% + var(--slide-bar-width)); left: calc(-1 * var(--slide-bar-width) / 2); background: transparent; height: 100%; overflow: hidden; border: 0; margin: 0; -webkit-appearance: none; -moz-appearance: none; appearance: none; touch-action: manipulation;}
{%- capture thumbStyle -%}
  -webkit-appearance: none;
  height: 100vh;
  width: var(--slide-bar-width);
  background: transparent;
  box-shadow: none;
  cursor: pointer;
  pointer-events: auto;
  border: 0;
{%- endcapture -%}
before-after .slider::-webkit-slider-thumb { {{thumbStyle}} }
before-after .slider::-moz-range-thumb { {{thumbStyle}} }
before-after .custom-separator {position: absolute; top: 0; bottom: 0; left: 50%; transform: translateX(-50%); background: var(--overlay-color); width: 2px; }
before-after .custom-separator .icon {position: absolute; top: 50%; transform: translateY(-50%); font-size: 1.5em;}
before-after .custom-separator .icon-chevron-left {right: 0;}
before-after .custom-separator .icon-chevron-right {left: 0;}
