{%- if settings.analytics_enable_addon -%}
(function() {
  document.addEventListener('click', function(e) {
    //remember that 'closest' selector can match the element itself, 
    //instead 'querySelector' works on the child elements
    const titleSelector = 'h1, h2, h3, h4, h5, h6, .title, .group-title';
    const trackElementsSelector = 'a, button, input[type=button], input[type=submit], [data-ga-label]';
    const target = e.target.closest('[data-ga-label]') || e.target.closest(trackElementsSelector);
    //only allow for custom targets or specific clickable elements
    if (!target) {
      return;
    }
    var findPrevElement = function(element) {
      if (element.previousElementSibling) {
        return element.previousElementSibling;
      } else if (element.parentElement && !element.classList.contains('shopify-section')) {
        return element.parentElement;
      }
      return null;
    }
    var findTitleOf = function(element) {
      var ret = element.matches(titleSelector) ? element : element.querySelector(titleSelector);
      if (!ret) {
        //ret = element.parentElement ? element.parentElement.querySelector(titleSelector) : null;
        if (!ret) {
          var prevElem = findPrevElement(element);
          if (prevElem) {
            ret = findTitleOf(prevElem)
          }
        }
      } 
      return ret;
    }
    var getText = function(element) {
      var ret = '';
      if (element) {
        ret = element.dataset.gaLabel || element.ariaLabel || element.innerText;
      }
      return ret;
    }
    var gaAction = target.closest('[data-ga-action]');
    var gaCategory = target.closest('[data-ga-category]');
    var gaType = target.closest('[data-ga-type]');
    var gaTitle = target.closest('[data-ga-title]');
    var category = '';
    var section = target.closest('.shopify-section');
    var action = gaAction ? gaAction.dataset.gaAction : (e.type + ' ' + (target.tagName == 'A' ? 'LINK' : target.tagName).toLowerCase()).replaceAll(' ', '_');
    var source = gaType ? gaType.dataset.gaType : (section ? Array.from(section.classList).find(x=>x.indexOf('type-')>-1) || '' : '');
    var targetTitle = gaTitle || findTitleOf(target);
    var targetTitleText = targetTitle ? getText(targetTitle) : '';
    var label = getText(target);
    
    // Convert "type-page-main" to "Page_Main" (matches the old class naming convention)
    source = source.replace('type-', '')
      .split('-') // ["page", "main"]
      .map(word => word.charAt(0).toUpperCase() + word.slice(1)) // ["Page", "Main"]
      .join('_');
      
    //don't trigger events on empty labels, like carousel arrow buttons
    if (!label) {
      return;
    }

    if (gaCategory) {
      category = gaCategory.dataset.gaCategory;
    } else {
      if (section) {
        var title = section.querySelector('h1, h2')// section.querySelector(titleSelector) <- this is too wide, often getting the first item title if the section doesn't have a title;
        if (title) {
          category = getText(title);
        }
      }
      if (!category && !source) {
        var tag = target.closest('header, main, footer, aside, body');
        if (tag) {
          category = tag.tagName;
        }
      }
    }

    var dataCategory = [];
    var dataLabel = [];
    if (source) dataCategory.push(source);
    if (category) dataCategory.push(category);
    if (targetTitleText) dataLabel.push(targetTitleText);
    dataLabel.push(label);
    var eventData = {eventCategory: dataCategory.join(' - '), eventLabel: dataLabel.join(' - ')};
    
    {% if settings.analytics_platform_target == 'ga' %}
    if (window.gtag) {
      delete eventData.eventAction;
      gtag('event', action,  {...eventData});
    } 
    {% elsif settings.analytics_platform_target == 'gtm' %}
    if (window.dataLayer) {
      dataLayer.push({
        event: 'analytics_event',
        ...eventData
      })
    }
    {% endif %}
    
  });
})()
{%- endif -%}

