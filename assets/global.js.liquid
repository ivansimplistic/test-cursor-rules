if(!customElements.get('text-changer')) {
  class TextChanger extends HTMLElement {
    connectedCallback() {
      this.updateText(this);
    }
  
    disconnectedCallback() {
      clearInterval(this.textInterval)
    }
  
    updateText(mainElement){
      var wordsArray = mainElement.dataset.text.split("|");
      mainElement.innerHTML = wordsArray[0]
      var count = 0;
      this.textInterval = setInterval(function () {
        count++;
        mainElement.innerHTML = wordsArray[count % wordsArray.length];
      }, mainElement.dataset.interval); 
    }
  }
  customElements.define('text-changer', TextChanger);
}
