.menu-below-header #mobile-menu {box-shadow: none;}
.menu-below-header #mobile-menu .head {display: none;}
#mobile-menu {display: block; outline: none; visibility: hidden; overflow: hidden; position: fixed; top: 0; bottom: 0; z-index: 150;}
#mobile-menu.open {visibility: visible;}
#mobile-menu .wrapper {height: 100%;}
#mobile-menu .content {position: relative; overflow: hidden;}
#mobile-menu .menu-links {position: relative; height: 100%; overflow-y: auto; overflow-x: hidden;}
#mobile-menu .menu-links .item {padding: 0 var(--slide-in-modal-padding);}
#mobile-menu .menu-links .item-inner {position: relative;}
#mobile-menu .menu-links .item-inner .badge {margin-left: 0.5em; z-index: initial;}
#mobile-menu .menu-links .item-inner > .item-padding {flex: 1; padding: 1.5rem 0; line-height: 1.5;} 
#mobile-menu .menu-links .item svg {font-size: 1.1em; transition: transform var(--animation-speed-medium) linear;}
#mobile-menu .menu-links .item.active > .item-inner > button svg.icon-chevron-down {-ms-transform: rotateX(180deg); -webkit-transform: rotateX(180deg); transform: rotateX(180deg);}
#mobile-menu .main-list {color: var(--scheme-text-color);}
#mobile-menu .main-list .item:not(.back-item) > .item-inner > .item-padding {font-size: var(--font-size); font-weight: var(--font-weight); text-transform: var(--text-transform); letter-spacing: var(--letter-spacing);}
#mobile-menu .main-list .item:not(.back-item) button {font-size: max(1.5rem, calc(var(--font-size) * 0.7)); position: relative; margin: -1.5rem; padding: 1.5rem; box-sizing: border-box; line-height: inherit;}
#mobile-menu .main-list.borders-true .item + .item > .item-inner {border-top: 1px solid var(--scheme-borders-color);}
#mobile-menu .main-list.borders-main .item a,
#mobile-menu .main-list.borders-false .item a {line-height: 1.1;}
#mobile-menu .main-list svg + .title {padding-left: 1rem;}
#mobile-menu .menu-links .main-list.borders-main > .item {padding: 0; margin: 0 var(--slide-in-modal-padding); }
#mobile-menu .menu-links .main-list.borders-main > .item:not(:first-child) {border-top: 1px solid var(--scheme-borders-color);}
#mobile-menu .menu-links .main-list.borders-main > .item > .submenu > .submenu-inner {padding-left: 0;}
#mobile-menu .menu-links .main-list.borders-main > .item > .item-inner > a {font-size: calc(var(--font-size) + 2px);}
#mobile-menu .menu-links .main-list.borders-main .submenu .item .item-inner > .item-padding {padding-top: 0.5em;}
#mobile-menu .menu-links .main-list.borders-main .submenu .item:not(:last-child) .item-inner > .item-padding {padding-bottom: 0.75em;}
#mobile-menu .menu-links .secondary-list {padding-top: 1rem;}
#mobile-menu .menu-links .secondary-list .item-inner > .item-padding {padding: 0.5rem 0;}

#mobile-menu .extras {position: relative;}
#mobile-menu .extras.top {margin-bottom: 1em; padding: 1.5rem 0;}
#mobile-menu .extras.bottom {margin-top: 1em; padding: 0.5rem 0;}
#mobile-menu .extras .item.search:first-child .item-inner > .item-padding {padding-top: 0;}
#mobile-menu .extras .item.search:last-child .item-inner > .item-padding {padding-bottom: 0;}
#mobile-menu .extras svg {margin-right: 1em;}
#mobile-menu.from-right {right: calc(-1 * var(--slide-in-modal-width)); transition-property: right, visibility;}
#mobile-menu.from-right.open {right: 0;}
#mobile-menu.from-left {left: calc(-1 * var(--slide-in-modal-width)); transition-property: left, visibility;}
#mobile-menu.from-left.open {left: 0;}
#mobile-menu.from-fade {left: 0; right: 0; opacity: 0; transition-property: opacity, visibility;}
#mobile-menu.from-fade.open {opacity: 1;}
#mobile-menu .featured-banners {padding: 0 var(--slide-in-modal-padding); --grid-gap: 1.5rem; margin-top: var(--grid-gap);}
#mobile-menu .featured-banners .grid-item {margin-bottom: var(--grid-gap);}
#mobile-menu .featured-banners .img-simple-overlay .caption p {font-size: 0.9em;}
#mobile-menu .submenu.expandable .featured-banners {padding: 0; margin-bottom: var(--grid-gap);}
#mobile-menu .btn {width: 100%;}
#mobile-menu .social-links .btn {width: 2em;}
#mobile-menu .social-links svg {margin: 0;}

#mobile-menu .submenu.expandable .submenu-inner {padding: 0 0 0 2rem;}
#mobile-menu .main-list.borders-true .submenu.expandable {border-top: 1px solid var(--scheme-borders-color);}
#mobile-menu .submenu.expandable .item {margin: 0 calc(var(--slide-in-modal-padding) * -1);}
#mobile-menu .submenu.expandable .item:last-child {padding-bottom: 0;}

#mobile-menu .submenu.slide {padding: 0.6em 0 0; z-index: 1; opacity: 0; filter: alpha(opacity=0); visibility: hidden; position: absolute; top: 0; bottom: 0; left: 101%; width: 100%; height: 100%; overflow-y: auto; overflow-x: hidden; transition-property: left, right, visibility, opacity;}
#mobile-menu .submenu.slide.open {left: 0; opacity: 1; visibility: visible;}
#mobile-menu .submenu.slide .submenu-inner {padding: 0;}
#mobile-menu .back-text {flex: 1; padding-left: 1em; cursor: pointer; margin: 0;}
#mobile-menu .main-list .item button.back-button {font-size: 1em;}
