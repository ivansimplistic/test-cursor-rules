{%- if settings.combined_products_support_mode == 'single_page_async' -%}
  if (!$s.PDPLoader) {
    $s.PDPLoader = new function() {
      const _pdps = {};
      this._pdps = _pdps; // for debugging
      let uidSequence = 0; // Used to generate unique section IDs as they can be pulled from the same PDP template.
      // Get the main product section of a PDP, used by product cards.
      this.getMainSection = (productUrl, container) => {
        productUrl = productUrl.split('?')[0];
        productUrlKey = productUrl;
        let view = '';
        if (!container) {
          container = document;
        }
        productUrlKey += '?section_id=product_card_ajax';
        let el = container.querySelector(`.product-main-element[data-product-url="${productUrl}"]`);
        if (el) {
          return Promise.resolve(()=>{return el});
        }
        if (!_pdps[productUrlKey]) {
          _pdps[productUrlKey] = new Promise((resolve, reject) => {
            fetch(productUrlKey)
              .then(response => response.text())
              .then(html => {
                let parser = new DOMParser();
                uidSequence++;
                html.replaceAll('shopify-section-product_card_ajax', 'card-'+uidSequence+'-shopify-section-product_card_ajax');
                let doc = parser.parseFromString(html, 'text/html');
                let el = doc.querySelector(`.product-main-element[data-product-url="${productUrl}"]`);
                resolve(()=>{return el.cloneNode(true)});
              })
          });
        }
        return _pdps[productUrlKey];
      }

      // Get all the sections of a PDP, used by product-main PDP and quickview.
      this.getAllSections = (productUrl, container) => {
        productUrl = productUrl.split('?')[0];
        productUrlKey = productUrl;
        let view = '';
        if (!container) {
          container = document;
        }
      
        // Check if we already have the sections cached
        let sectionsKey = productUrlKey + '_sections';

        let sectionsWithLoadUrl = Array.from(container.querySelectorAll(`.shopify-section[data-load-url="${productUrl}"]`));
        if (sectionsWithLoadUrl.length > 0) {
          return Promise.resolve(() => { return sectionsWithLoadUrl; });
        }

        let el = container.querySelector(`product-main.product-main-element[data-product-url="${productUrl}"]`);
        if (el) {
          let sections = Array.from(el.closest('.shopify-section').parentNode.querySelectorAll('.shopify-section'));
          sections.forEach(section => {
            section.setAttribute('data-load-url', productUrl);
          })
          return Promise.resolve(()=>{return sections});
        }        
        
        if (!_pdps[sectionsKey]) {
          _pdps[sectionsKey] = new Promise((resolve, reject) => {
            fetch(productUrlKey)
              .then(response => response.text())
              .then(html => {
                let parser = new DOMParser();
                let tempDoc = parser.parseFromString(html, 'text/html');
                uidSequence++;
                const idPrefix = 'pdp-' + uidSequence+'-';
                tempDoc.querySelectorAll('[id]').forEach((el,ix) => {
                  html = html.replaceAll(el.id, idPrefix + el.id);
                });
                
                // Clone the sections
                const getter = () => {
                  let doc = parser.parseFromString(html, 'text/html');
                  let sections = doc.querySelectorAll('main .shopify-section');
                  
                  let clonedSections = Array.from(sections).map(section => {
                    section.setAttribute('data-load-url', productUrl);
                    return section.cloneNode(true);
                  });
                  return clonedSections;
                }
                
                resolve(getter);
              })
          });
        }
        return _pdps[sectionsKey];
      }
    }
  }
{%- endif -%}

if(!customElements.get('product-main')) {
  class ProductMain extends HTMLElement {
    static instanceCount = 0;

    constructor() {
      super();
      this.sectionId = this.dataset.section + '-' + ProductMain.instanceCount++; // for Unique product component IDs
      this.productData = JSON.parse(this.querySelector('[type="application/json"][data-product-json]').textContent);
      this.fillProductData();
      this.variantsElement = this.querySelector('product-variants');
      this.sellingPlanElement = this.querySelector('product-selling-plan');
      this.quantityElement = this.querySelector('.quantity-input');
      this.badgesSale = this.querySelectorAll('.badge.sale');
      this.badgesSoldOut = this.querySelectorAll('.badge.sold-out');
      this.variantTitleElements = this.querySelectorAll('[data-variant-title]');
      this.optionValues = {}
      const requiredOptionsSetting = ({{ settings.variants_selection_required | split: ',' | json}} || []).concat(this.dataset.manualSelect ? this.dataset.manualSelect.split(',') : []).map(x=>x.trim());
      const requiredOptionsSettingUnique = [...new Set(requiredOptionsSetting)];
      this.requiredOptions = this.productData.options_with_values.filter(x=>(requiredOptionsSettingUnique.indexOf(x.name)>-1 || requiredOptionsSettingUnique.indexOf('*')>-1) && x.values.length>1).map(x=>x.name);
      if (this.requiredOptions.length > 0) {
        this.setAttribute('data-required', 'true');
      }
      if (this.quantityElement) {
        this.quantityElement.addEventListener('change', this.onQuantityElementChange.bind(this));
      }
      this.addEventListener('variantChange', this.onVariantChange.bind(this));

      {% if settings.seo_aggregate_rating_source contains 'mutation_' %}
      this.seoRating();
      {% endif %}

      {%- if settings.combined_products_support_mode == 'single_page_async' -%}
        //preload connected products() if up to 3 products in total;
        (()=>{
          if (this.tagName == 'PRODUCT-MAIN') {
            const products = {};
            // Instead of looking at variants, look through options_with_values for product_url
            this.productData.options_with_values?.forEach(option => {
              option.values?.forEach(value => {
                if (value.product_url) {
                  // Use product_url as the key since product_id is not available anymore
                  let key = value.product_url;
                  products[key] = value.product_url;
                }
              });
            });
            if (Object.keys(products).length <= 3) {
              for (const [key, value] of Object.entries(products)) {
                $s.PDPLoader.getAllSections(value, this.closest('.shopify-section').parentNode);
              }
            }
          }
        })()
      {%- endif -%}
        
    }

    fillProductData() {
      const isMerge = this.productData.is_product_merge;
      {% if settings.combined_products_support_mode == 'disabled' %}
        this.productData.options_with_values.forEach(option=>{
          option.values = option.values.map(x=>{
            return {"value": x, "available": true }; //availability calculated by filtered variants in getOptionValues function
          });
        });
      {%- endif  -%}
      {%- if settings.merge_variants_support -%}
      if (isMerge) {
        this.productData.options_with_values.forEach((x,index)=>{
          for (let v of  this.productData.variants) {
            let option = x.values.find(y=>y.value==v.options[index]);
            if (!option) {
              option = {value: v.options[index], available: v.available};
              x.values.push(option);
            }
            option.available = option.available || v.available;
          }
        });
      }
      {%- endif -%}
      if (this.productData.is_product_main) {
        let altPerProduct = {}
        this.productData.media = Array.from(this.querySelectorAll('product-gallery [data-media-id]')).map((media)=>{
          let alt;
          if (!isMerge) {
          {%- if settings.merge_variants_support -%}
            alt = media.getAttribute('data-media-alt');
          } else {
            let id = media.getAttribute('data-product-id');
            if (altPerProduct[id]) {
              alt = altPerProduct[id];
            } else {
              let variant = this.productData.variants.find(v=>v.product_id == id);
              alt = this.productData.options_with_values[0].name + ': ' + variant.options[0];
              altPerProduct[id] = alt;
            }
            alt = alt + (media.getAttribute('data-media-alt') ? ';' + media.getAttribute('data-media-alt') : '');
          {%- endif -%}
          }
          return {
            "alt": alt,
            "id": media.getAttribute('data-media-id')
          };
        });
      }

    }

    isSwatchSelected() {
      return this.requiredOptions.length == 0 || this.requiredOptions.length < this.productData.options_with_values.length;
    }

    required(option, newValue) {
      var ix = this.requiredOptions.indexOf(option);
      if (typeof(newValue)!='undefined') {
        if (ix > -1) {
          this.requiredOptions.splice(ix, 1);
          if (this.requiredOptions.length == 0) {
            this.setAttribute('data-required', 'false');
          }
          return false;
        }
      }
      return ix > -1;
    }

    getCurrentVariant() {
      return this.variantsElement.getCurrentVariant();
    }
    getCurrentPlan() {
      return this.sellingPlanElement?.getCurrentPlan();
    }
    getQuantity() {
      return this.quantityElement ? this.quantityElement.value : 1;
    }
    onQuantityElementChange() {
      this.dispatchEvent(new CustomEvent('quantityChange', {detail: {"quantity":this.getQuantity()}}));
    }
    onVariantChange() {
      // Lightweight update of elements that not worth creating their own components
      var variant = event.detail.variant;
      this.variantTitleElements.forEach(element=>{
        element.innerHTML = variant.title;
      });
      this.badgesSale.forEach(element=>{
        var sale = '';
        var percent = Math.floor((1 - variant.price / variant.compare_at_price) * 100);
        if (percent > 0) {
          sale = element.dataset.msgtpl.replace('[percent]', percent);
        }
        element.style.display = variant.available && sale ? '' : 'none';
        element.innerHTML = sale;
      });
      this.badgesSoldOut.forEach(element=>{
        element.style.display = variant.available ? 'none' : '';
      });
      {%- comment -%}
      //Example "Add price to swatches"
      //- not implemented for product-dropdown because it is generally not needed, 
      //- selling plans with discount not considered
      //1. In the buildOptions function of ProductSwatches add the following to include the price: <span data-variant-price-option="${option.value}"></span>
      //2. Uncomment the code below:
      this.querySelectorAll('product-swatch [data-variant-price-option]').forEach(x=>{
        var optionNumber = x.closest('product-swatch').dataset.option;
        var value = x.dataset.variantPriceOption;
        var variantOptions = [...variant.options]; //get array copy
        variantOptions[optionNumber - 1] = value;
        var targetVariant = this.productData.variants.find((x)=>{
          return x.options.length==variantOptions.length
            && x.options.every((val, index) => val === variantOptions[index]);
        });
        x.innerHTML = $s.formatMoney(targetVariant.price).replace('.00', '');
      })
      {%- endcomment -%}
    }

    {%- if settings.seo_aggregate_rating_source contains 'mutation_' -%}
    seoRating() {
      function watchForElementAndInjectSchema(targetSelector, elementSelector) {
        const target = document.querySelector(targetSelector);
        if (!target) {
          console.warn(`Target element '${targetSelector}' not found`);
          return;
        }

        function processElement(found) {
          const reviews = parseInt(found.getAttribute('data-reviews'), 10);
          const rating = parseFloat(found.getAttribute('data-rating'));

          if (isNaN(reviews) || isNaN(rating)) {
            console.warn('Invalid data-reviews or data-rating attributes');
            return;
          }

          const scripts = document.querySelectorAll('script[type="application/ld+json"]');
          for (const script of scripts) {
            try {
              const json = JSON.parse(script.textContent);
              if (json['@type'] === 'Product') {
                json.aggregateRating = {
                  "@type": "AggregateRating",
                  "ratingValue": rating,
                  "reviewCount": reviews
                };

                script.textContent = JSON.stringify(json, null, 2);
                break;
              }
            } catch (e) {
              console.warn('Failed to parse JSON-LD script:', e);
            }
          }
        }

        const existing = target.querySelector(elementSelector);
        if (existing) {
          processElement(existing);
          return;
        }

        const observer = new MutationObserver(() => {
          const found = target.querySelector(elementSelector);
          if (found) {
            observer.disconnect();
            processElement(found);
          }
        });

        observer.observe(target, {
          childList: true,
          subtree: true,
        });
      }

      {%- if settings.seo_aggregate_rating_source == 'mutation_stamped' -%}
      watchForElementAndInjectSchema('.stamped-product-reviews-badge', '.stamped-badge-caption');
      {%- endif -%}
    
    }
    {%- endif -%}
  }
  customElements.define('product-main', ProductMain);

  class ComponentProductCardAtc extends ProductMain {
    constructor() {
      super()
      this.swatches = this.querySelector('.swatch-group')
      this.addEventListener('variantChange', this.onVariantChange.bind(this));
      this.defaultImage = this.querySelector('.img.main').getAttribute('data-srcset');
      this.currentImageUrl = '';
      this.imageObserver = null;
      this.clickOutHandler = null;
      let imageContainer = this.querySelector('.image-container');
      if (imageContainer && imageContainer.querySelector('.hover-img')) {
        let hover = false;
        this.addEventListener('mouseleave', (e)=>{
          hover && (hover=false,imageContainer.classList.remove("hover"));
        });
        this.addEventListener('mousemove', (e)=>{
          let bounds = imageContainer.getBoundingClientRect();
          if (e.y>bounds.top && e.y<bounds.bottom && e.x>bounds.left && e.x<bounds.right) {
            hover || (hover=true,imageContainer.classList.add("hover"))
          } else {
            hover && (hover=false,imageContainer.classList.remove("hover"));
          }
        });
      }
      
      this.optionsButton = this.querySelector('.atc-options');
      if (this.optionsButton) {
        this.optionsButton.addEventListener('click', this.openOptions.bind(this));
        {% if settings.product_card_cta_style == 'bubbles add-cta' %}
          if (this.productData.options_with_values.some(x=>x.values.some(y=>y.available)) || this.productData.variants.some(x=>x.available)) {
            this.optionsButton.innerHTML = this.optionsButton.dataset.enabledText;
            this.optionsButton.removeAttribute('disabled');
          } else {
            this.optionsButton.innerHTML = this.optionsButton.dataset.disabledText;
          }
          this.optionsButton.classList.remove('hide');
        {% endif %}
      }


      this.quickViewBtn = this.querySelector('.quick-view-trigger')
      if(this.quickViewBtn) {
        this.quickViewBtn.addEventListener('click', this.openQuickView.bind(this));
      }

      var self = this;
      if (self.classList.contains('colors-out')) {
        setTimeout(function() { //workaround on ajax call, the following code mistakenly inits ProductSwatch before ProductVariants
          var origSwatches = self.querySelector('product-swatch.color-swatches');
          if (origSwatches) {
            //need to duplicate the whole product-variants component
            var pv = origSwatches.closest('product-variants');
            var tag = pv.outerHTML.replace('name="id"', '');
            var wrapper = document.createElement('div');
            wrapper.style.display = 'none';
            //must insert as Element, not HTML, otherwise the component would be reconstructed
            self.querySelector('add-to-cart-form').insertAdjacentElement('beforebegin', wrapper);
            tag = tag.replace('<product-swatch', '<product-swatch data-trim-options-limit="{{ settings.product_card_swatches_trim_limit }}"');
            wrapper.innerHTML = tag;
            //move the swatches inside the add-to-cart-form component to use existing css.
            self.querySelector('add-to-cart-form').insertAdjacentElement('afterbegin', wrapper.querySelector('product-swatch.color-swatches'));
          }
        }, 10);
      }
      if (window.LinkPrefetch && window.LinkPrefetch.addHoverListener) {
        window.LinkPrefetch.addHoverListener(this);
      }
    }

    // Added to match colors on product cards loaded through ajax, probably not needed for main product sections
    copySchemeFrom(el) {
      var lookForClasses = ['scheme'{% for scheme in settings.color_schemes %},'color-{{ scheme.id }}'{% endfor %}, 'same-scheme-true', 'same-scheme-false'];
      lookForClasses.forEach(name=>{
        if (el.classList.contains(name)) {
          this.classList.add(name);
        } else {
          this.classList.remove(name);
        }
      })
      
    }

    openOptions(e) {
      e.preventDefault()
      const currentVariant = this.getCurrentVariant();
      if (currentVariant && currentVariant.available) {
        const inputs = this.querySelectorAll(
          'input:not([type="hidden"]):not([type="button"]):not([type="submit"]):not([type="reset"]), textarea, select'
        );
        if (inputs.length==0) {
          this.querySelector('.btn.add').click();
          return;
        }
      }
      
      if (this.querySelector('.atc-options-wrapper').classList.contains('open')) {
        return;
      }
      var container = this.querySelector('.atc-options-wrapper form');
      this.querySelector('.atc-options-wrapper').classList.add('open');
      $s.trapFocus(container);
      var self = this;
      if (!this.clickOutHandler) {
        this.querySelector('.close').addEventListener('click', this.closeOptions.bind(this));
      }
      this.clickOutHandler = function(evt) {
        if(container !== evt.target && !container.contains(evt.target)) {
          self.closeOptions.bind(self)();
        }
      }
      document.addEventListener('mousedown', this.clickOutHandler);
    }
    closeOptions() {
      this.querySelector('.atc-options-wrapper').classList.remove('open');
      document.removeEventListener('mousedown', this.clickOutHandler);
      $s.removeTrapFocus();
    }

    openQuickView(e) {
      e.preventDefault()
      $s.showLoadingOverlay();
      var qvUrl = this.quickViewBtn.dataset.url;
      $s.get({
        url: qvUrl,
        success: (html)=>{
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, "text/html");
          var section = doc.querySelector('.product-main-element').closest('.shopify-section');
          var enhancedDescription = section.querySelector('.enhanced-description');
          if (enhancedDescription && enhancedDescription.querySelector('.expandable-default-open')) {
            enhancedDescription.querySelector('.accordion.open').classList.remove('open');
            enhancedDescription.querySelector('[aria-expanded=true]').ariaExpanded = false;
            enhancedDescription.querySelector('.expandable-default-open').classList.remove('expandable-default-open');
          }
          $s.openModal(section, 'product-quick-view');
          $s.globalEval(section);
        },
        always: (html)=>{
          $s.hideLoadingOverlay();
        }
      })
    }

    onVariantChange(event) {
      super.onVariantChange(event);
      var variant = event.detail.variant;
      var image = variant.featured_media && super.isSwatchSelected() ? variant.featured_media : null;
      var img = this.querySelector('.img.main');
      var width = Math.ceil(img.width / 100) * 100;
      if (image && img.classList.contains('under-video')) {
        this.querySelector('.video-wrap').remove();
        img.classList.remove('under-video');
      }

      if (img.classList.contains('lazyload')) {
        img.setAttribute('data-srcset', image ? $s.buildImgSrcset(image.src, image.width) : this.defaultImage);
      } else {
        this.currentImageUrl = image ? $s.buildImgSrcset(image.src, image.width) : this.defaultImage;
        if (!this.imageObserver) {
          if (!img.classList.contains('lazyloaded')) {
            this.imageObserver = new MutationObserver(mutations => {
              if (img.classList.contains('lazyloaded')) {
                this.imageObserver.disconnect();
                this.imageObserver = null;
                img.setAttribute('srcset', this.currentImageUrl);
              }
            });
            var config = { attributes: true, attributeFilter: ['class']};
            this.imageObserver.observe(img, config);
          } else {
            img.setAttribute('srcset', this.currentImageUrl);
          }
        }
      }

      // Update urls to variant
      var links = this.querySelectorAll('.product-card-url[href]');
      if (links.length > 0 && this.requiredOptions.length < this.productData.options_with_values.length) {
        var productUrl = new URL(links[0].getAttribute('href'), location.origin);
        productUrl.searchParams.set('variant', variant.id);
        links.forEach(link=>{
          link.setAttribute('href', productUrl.toString());
        });
        if (this.quickViewBtn) {
          this.quickViewBtn.dataset.url = productUrl.toString();
        }
      }
    }
  }
  customElements.define('product-card-atc', ComponentProductCardAtc);
}

if(!customElements.get('product-buttons')) {
  class ProductButtons extends HTMLElement {
  	constructor() {
      super();
      this.mainElement = this.closest('.product-main-element');
      this.dynamicButtons = this.querySelector('.shopify-payment-button');
      this.mainAddButton = this.mainElement.querySelector('.btn.add');
      this.button = this.querySelector('.btn.add');
      if (this.button != this.mainAddButton) {
        this.button.addEventListener('click', (event)=>{
          event.preventDefault();
          event.stopImmediatePropagation();
          this.mainAddButton.click();
        });
      }

      this.mainElement.addEventListener('variantChange', (e)=>{
        var requiredBtn = this.querySelector('.btn.selection-required');
        if (this.required() && requiredBtn) {
          if (this.dynamicButtons) {
            this.dynamicButtons.classList.add('hide');
          }
          requiredBtn.style.display = '';
          requiredBtn.innerHTML = this.requiredMessage;
        } else if(e.detail.variant && e.detail.variant.available) {
          if (this.dynamicButtons) {
            this.dynamicButtons.classList.remove('hide');
          }
          this.querySelector('.btn.add').style.display = '';
          this.querySelector('.sold-out-message').style.display = 'none';
          if (requiredBtn) requiredBtn.style.display = 'none';
      	} else {
          if (this.dynamicButtons) {
            this.dynamicButtons.classList.add('hide');
          }
          this.querySelector('.btn.add').style.display = 'none';
          this.querySelector('.sold-out-message').style.display = '';
          if (requiredBtn) requiredBtn.style.display = 'none';
      	}
      });
    }

    required() {
      if (this.mainElement.requiredOptions.length > 0) {
        this.requiredMessage = '';
        var label = this.mainElement.requiredOptions[0];
        var firstLetter = label[0].toLowerCase();
        var prep = 'aeiou'.indexOf(firstLetter)>-1 ? 'an' : 'a'; //english support only
        this.requiredMessage = lngg.product_main__select_option_label.replace('Select a ', 'Select ' + prep + ' ').replace(new RegExp(/{% raw %}{{ *option_name *}}{% endraw %}/), label);
        return true;
      }
      return false;
    }
  }
  customElements.define('product-buttons', ProductButtons);
}

