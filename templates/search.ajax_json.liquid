{%- layout none -%}
{%- capture results -%}
  {%- for item in search.results limit:5 -%}
    {%- assign product = item -%}
    {%- assign image = product.featured_image -%}
    { 
      "title"    : {{ product.title | json }},
      "url"      : {{ product.url | json }},
      "thumbnail": {% if image != blank %}{{ image | image_url: width: 50 | json }}{% else %}{{ 'placeholder_image.svg' | asset_url | json}}{% endif %},
    }
    {%- unless forloop.last %},{%- endunless -%}
  {%- endfor -%}
{%- endcapture -%}
{
  "results_count": {{ search.results_count }},
  "results": [{{ results }}]
}